---
const items = [
  {
    title: 'Laboratorium TAURON',
    desc: 'Inteligentne domy i automatyka przemysłowa &mdash; doposażone w ramach konkursu TAURONA.',
    svg: '<path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" stroke="currentColor" stroke-width="2"/>',
  },
  {
    title: 'Pracownia OZE',
    desc: 'Nowoczesne laboratorium energetyki odnawialnej z projektu &bdquo;Efektywne Funkcjonalne Szkoły&rdquo;.',
    svg: '<circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>',
  },
  {
    title: 'Pracownie informatyczne',
    desc: 'W pełni wyposażone sale komputerowe, partner GitHub Campus Program.',
    svg: '<rect x="2" y="3" width="20" height="14" rx="2" ry="2" stroke="currentColor" stroke-width="2"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>',
  },
  {
    title: 'Pracownie logistyczne',
    desc: 'Sale magazynowe i logistyczne we współpracy z lokalnymi firmami.',
    svg: '<path d="M21 10c0 5-9 11-9 11s-9-6-9-11a9 9 0 0118 0z" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2"/>',
  },
  {
    title: 'Wirtualna strzelnica',
    desc: 'Nowoczesna strzelnica wirtualna dostępna dla uczniów i szkół powiatowych.',
    svg: '<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>',
  },
  {
    title: 'Biblioteka szkolna',
    desc: 'Wypożyczalnia i czytelnia &middot; ~13 779 woluminów &middot; Narodowy Program Rozwoju Czytelnictwa.',
    svg: '<path d="M4 19.5A2.5 2.5 0 016.5 17H20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" stroke="currentColor" stroke-width="2"/>',
  },
  {
    title: 'Zielona Pracownia',
    desc: 'Projekt proekologiczny z dofinansowaniem WFOŚ.',
    svg: '<path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2zM22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" stroke="currentColor" stroke-width="2"/>',
  },
  {
    title: 'Warsztaty szkolne',
    desc: 'Maszyny, urządzenia, stoły ślusarskie i pracownia rysunku technicznego.',
    svg: '<path d="M9.59 4.59A2 2 0 1111 8H2m10.59 11.41A2 2 0 1014 16H2m15.73-8.27A2.5 2.5 0 1119.5 12H2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>',
  },
];
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
  {items.map((item) => (
    <div class="p-5 rounded-xl bg-white dark:bg-navy-800/60 border border-gray-200 dark:border-navy-700 shadow-sm hover:shadow-md transition-all">
      <div class="w-10 h-10 rounded-lg bg-primary-100 dark:bg-primary-800/40 flex items-center justify-center">
        <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" viewBox="0 0 24 24" fill="none" aria-hidden="true" set:html={item.svg} />
      </div>
      <h3 class="mt-3 font-semibold text-slate-900 dark:text-white text-sm">{item.title}</h3>
      <p class="mt-1 text-xs text-slate-500 dark:text-slate-400 leading-relaxed"><Fragment set:html={item.desc} /></p>
    </div>
  ))}
</div>
