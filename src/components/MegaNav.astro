  book: '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>',
  'book-open': '<path d="M2 4h7a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 4h-7a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h8z"></path>',
  briefcase: '<rect x="2" y="7" width="20" height="14" rx="2"></rect><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"></path><path d="M2 13h20"></path>',
  calendar: '<rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path>',
  'calendar-days': '<rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path><path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"></path>',
  check: '<path d="M9 11l3 3L22 4"></path><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>',
  clipboard: '<path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"></path><rect x="9" y="3" width="6" height="4" rx="1"></rect><path d="M9 14l2 2 4-4"></path>',
  clock: '<circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path>',
  file: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><path d="M14 2v6h6"></path><path d="M8 13h8M8 17h8"></path>',
  globe: '<circle cx="12" cy="12" r="10"></circle><path d="M2 12h20"></path><path d="M12 2a15 15 0 0 1 0 20"></path><path d="M12 2a15 15 0 0 0 0 20"></path>',
  graduation: '<path d="M22 10 12 5 2 10l10 5 10-5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"></path>',
  info: '<circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path>',
  news: '<path d="M4 22h16a2 2 0 0 0 2-2V4H6v16a2 2 0 0 1-2 2z"></path><path d="M4 22a2 2 0 0 1-2-2v-9h4"></path><path d="M10 8h8M10 12h8M10 16h5"></path>',
  people: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.9"></path><path d="M16 3.1a4 4 0 0 1 0 7.8"></path>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>',
  spark: '<path d="M13 2 3 14h8l-1 8 10-12h-8l1-8z"></path>',
  terminal: '<polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line>',
  users: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.9"></path><path d="M16 3.1a4 4 0 0 1 0 7.8"></path>',
};

const iconForHref = (href: string) => {
  const key = (linkIcons as Record<string, keyof typeof iconPaths>)[href] ?? 'info';
  return iconPaths[key] ?? iconPaths.info;
};
---

<header class="site-header">
  <div class="site-header__top">
    <a href="/" class="site-brand" aria-label="ZSEiU - strona główna">
      <img src="/images/logo-szkoly-light.png" alt="" class="h-12 w-auto dark:hidden" />
      <img src="/images/logo-szkoly-dark.png" alt="" class="hidden h-12 w-auto dark:block" />
      <span class="min-w-0">
        <span class="block truncate text-lg font-bold tracking-tight sm:text-xl">ZSEiU</span>
        <span class="hidden truncate text-xs text-gray-500 dark:text-slate-400 sm:block">Łaziska Górne</span>
      </span>
    </a>

    <div class="site-emblems" aria-label="Symbole państwowe i powiatowe">
      <img src="/images/Herb_Polski.svg" alt="Godło Polski" />
      <img src="/images/Coat_of_arms_of_Upper_Silesia.svg" alt="Herb Śląska" />
      <img src="/images/Herb_powiatu.svg" alt="Herb powiatu mikołowskiego" />

    
    </div>

    <div class="site-quick-links" aria-label="Szybkie linki">
      {quickLinks.map(([label, href]) => (
        <a href={href} target={isExternal(href) ? '_blank' : undefined} rel={isExternal(href) ? 'noopener noreferrer' : undefined}>
          {label}
        </a>
      ))}
    </div>

    <div class="site-search">
      <label for="search-input" class="sr-only">Szukaj</label>
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"></circle>
        <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
      </svg>
      <input id="search-input" type="search" placeholder="Szukaj..." autocomplete="off" />
      <div id="search-results" class="search-popover hidden"></div>
    </div>

    <button id="theme-toggle" type="button" class="site-icon-button" aria-label="Przełącz tryb ciemny lub jasny" aria-pressed="false">
      <svg class="h-5 w-5 dark:hidden" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
      <svg class="hidden h-5 w-5 dark:block" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"></circle>
        <path d="M12 1v2M12 21v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M1 12h2M21 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
      </svg>
    </button>

    <button id="contrast-toggle" type="button" class="site-icon-button" aria-label="Włącz wysoki kontrast" aria-pressed="false">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"></circle>
        <path d="M12 3a9 9 0 0 1 0 18z" fill="currentColor"></path>
      </svg>
    </button>

    <div class="site-social" aria-label="Linki społecznościowe i BIP">
      <a href="https://zseiu.ssdip.bip.gov.pl/" target="_blank" rel="noopener noreferrer" aria-label="BIP">
        <img src="/images/bip_simple.svg" alt="" />
      </a>
      <a href="https://www.facebook.com/zseiu" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M24 12.1C24 5.4 18.6 0 12 0S0 5.4 0 12.1c0 6 4.4 11 10.1 11.9v-8.4h-3v-3.5h3V9.4c0-3 1.8-4.7 4.5-4.7 1.3 0 2.7.2 2.7.2v3h-1.5c-1.5 0-2 .9-2 1.9v2.3h3.3l-.5 3.5h-2.8V24c5.8-.9 10.2-5.9 10.2-11.9z"></path>
        </svg>
      </a>
      <a href="https://www.instagram.com/zseiu_laziska/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M7.1 2h9.8A5.1 5.1 0 0 1 22 7.1v9.8a5.1 5.1 0 0 1-5.1 5.1H7.1A5.1 5.1 0 0 1 2 16.9V7.1A5.1 5.1 0 0 1 7.1 2zm0 2A3.1 3.1 0 0 0 4 7.1v9.8A3.1 3.1 0 0 0 7.1 20h9.8a3.1 3.1 0 0 0 3.1-3.1V7.1A3.1 3.1 0 0 0 16.9 4H7.1zm10.4 1.7a.8.8 0 1 1 0 1.6.8.8 0 0 1 0-1.6zM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"></path>
        </svg>
      </a>
    </div>

    <div id="mobile-nav" class="mobile-nav ml-auto">
      <button class="site-icon-button" aria-label="Otwórz menu" aria-expanded="false" aria-controls="mobile-nav__panel">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
      </button>
      <div class="mobile-nav__backdrop" aria-hidden="true"></div>
      <div id="mobile-nav__panel" class="mobile-nav__panel" role="dialog" aria-modal="true" aria-label="Nawigacja">
        <div class="mobile-search">
          <label for="mobile-search-input" class="sr-only">Szukaj</label>
          <input id="mobile-search-input" type="search" placeholder="Szukaj..." autocomplete="off" />
          <div id="mobile-search-results" class="search-popover mt-2 hidden overflow-hidden rounded-md border border-gray-100 dark:border-navy-700"></div>
        </div>
        <div class="mobile-nav__grid">
          {mobileSections.map((section) => (
            <section>
              <h2>{section.title}</h2>
              <ul>
                {section.links.map(([label, href]) => (
                  <li>
                    <a class="nav-link" href={href} target={isExternal(href) ? '_blank' : undefined} rel={isExternal(href) ? 'noopener noreferrer' : undefined}>
                      {label}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>
      </div>
    </div>
  </div>

  <nav class="mega-nav" aria-label="Główna nawigacja">
    <div class="mega-nav__inner">
      <a href="/" class="mega-nav-link">Strona główna</a>
      {sections.map((section, index) => (
        <div class="mega-menu" role="menu">
          <button class="mega-nav-link mega-trigger" type="button" aria-expanded="false" aria-controls={`mega-panel-${index}`} data-mega-trigger>
            {section.title}
            <svg class="ml-1 h-3 w-3" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </button>
          <div id={`mega-panel-${index}`} class={`mega-panel ${index > 1 ? 'mega-panel--right' : ''}`}>
            <div class="mega-panel__content">
              <aside>
                <p>{section.title}</p>
                <span>{section.desc}</span>
                {section.highlight && (
                  <a class="mega-highlight" href={section.highlight[1]}>
                    <strong>{section.highlight[0]}</strong>
                    <small>{section.highlight[2]}</small>
                  </a>
                )}
              </aside>
              <div class={`mega-panel__links ${section.groups.length === 1 ? 'is-single' : ''}`}>
                {section.groups.map((group) => (
                  <section>
                    <h2>{group.title}</h2>
                    <ul>
                      {group.links.map(([label, href, desc]) => (
                        <li>
                          <a class="mega-item" href={href} role="menuitem">
                            <span aria-hidden="true">
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconForHref(href)} />
                            </span>
                            <span>
                              <strong>{label}</strong>
                              <small>{desc}</small>
                            </span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </section>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
      <a href="/blog" class="mega-nav-link">Aktualności</a>
      <a href="/kontakt" class="mega-nav-link ml-auto">Kontakt</a>
    </div>
  </nav>
</header>

<script is:inline>
  (function () {
    function setupSearch(input, results) {
      if (!input || !results) return;

      var pagefind = null;
      var ready = false;

      function escapeHtml(value) {
        return String(value || '').replace(/[&<>"']/g, function (char) {
          return {
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#39;'
          }[char];
        });
      }

      import('/pagefind/pagefind.js').then(function (mod) {
        pagefind = mod;
        return mod.init();
      }).then(function () {
        ready = true;
      }).catch(function () {
        // Pagefind not available (dev mode)
      });

      var debounceTimer;
      input.addEventListener('input', function () {
        clearTimeout(debounceTimer);
        var query = input.value.trim();
        if (query.length < 2) {
          results.classList.add('hidden');
          return;
        }
        if (!ready) return;

        debounceTimer = setTimeout(function () {
          pagefind.search(query).then(function (searchResult) {
            var items = searchResult.results.slice(0, 8);
            return Promise.all(items.map(function (r) { return r.data(); }));
          }).then(function (data) {
            var html;
            if (data.length) {
              html = data.map(function (item) {
                var title = item.meta && item.meta.title ? item.meta.title : item.url;
                return '<a href="' + escapeHtml(item.url) + '" class="search-result-item">' +
                  '<span class="text-sm font-semibold">' + escapeHtml(title) + '</span>' +
                  '<span class="mt-1 block text-xs text-gray-500 dark:text-slate-400">' + (item.excerpt || '') + '</span></a>';
              }).join('');
            } else {
              html = '<div class="px-4 py-3 text-sm text-gray-500 dark:text-slate-400">Brak wyników</div>';
            }
            results.innerHTML = html;
            results.classList.remove('hidden');
          }).catch(function () {});
        }, 150);
      });

      input.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
          results.classList.add('hidden');
          input.blur();
        }
      });
    }

    setupSearch(document.getElementById('search-input'), document.getElementById('search-results'));
    setupSearch(document.getElementById('mobile-search-input'), document.getElementById('mobile-search-results'));

    function writePreference(key, value) {
      try {
        localStorage.setItem(key, value);
      } catch (e) {}
    }

    function updatePreferenceButtons() {
      var themeToggle = document.getElementById('theme-toggle');
      var contrastToggle = document.getElementById('contrast-toggle');
      var isDark = document.documentElement.classList.contains('dark');
      var isHighContrast = document.documentElement.classList.contains('high-contrast');

      if (themeToggle) {
        themeToggle.setAttribute('aria-pressed', String(isDark));
        themeToggle.setAttribute('aria-label', isDark ? 'Przełącz na tryb jasny' : 'Przełącz na tryb ciemny');
      }

      if (contrastToggle) {
        contrastToggle.setAttribute('aria-pressed', String(isHighContrast));
        contrastToggle.setAttribute('aria-label', isHighContrast ? 'Wyłącz wysoki kontrast' : 'Włącz wysoki kontrast');
      }
    }

    var themeToggle = document.getElementById('theme-toggle');
    if (themeToggle) {
      themeToggle.addEventListener('click', function () {
        var isDark = document.documentElement.classList.toggle('dark');
        writePreference('theme', isDark ? 'dark' : 'light');
        updatePreferenceButtons();
      });
    }

    var contrastToggle = document.getElementById('contrast-toggle');
    if (contrastToggle) {
      contrastToggle.addEventListener('click', function () {
        var isHighContrast = document.documentElement.classList.toggle('high-contrast');
        writePreference('contrast', isHighContrast ? 'high' : 'standard');
        updatePreferenceButtons();
      });
    }
    updatePreferenceButtons();

    const mobileNav = document.getElementById('mobile-nav');
    const mobileToggle = mobileNav ? mobileNav.querySelector('button') : null;
    const mobilePanel = document.getElementById('mobile-nav__panel');
    const mobileBackdrop = mobileNav ? mobileNav.querySelector('.mobile-nav__backdrop') : null;

    function getFocusable(el) {
      if (!el) return [];
      return Array.from(el.querySelectorAll('a[href], button:not([disabled]), input:not([disabled]), textarea:not([disabled]), select:not([disabled]), [tabindex]:not([tabindex="-1"])'));
    }

    function toggleMobileNav(forceOpen) {
      if (!mobileNav) return;
      const isOpen = forceOpen !== undefined ? forceOpen : !mobileNav.classList.contains('is-open');
      mobileNav.classList.toggle('is-open', isOpen);
      if (mobileToggle) mobileToggle.setAttribute('aria-expanded', String(isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';

      if (isOpen) {
        const focusable = getFocusable(mobilePanel);
        if (focusable.length) focusable[0].focus();
      } else {
        if (mobileToggle) mobileToggle.focus();
      }
    }

    if (mobileToggle && mobilePanel) {
      mobileToggle.addEventListener('click', () => { toggleMobileNav(); });

      mobilePanel.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          e.preventDefault();
          toggleMobileNav(false);
          return;
        }
        if (e.key === 'Tab') {
          const focusable = getFocusable(mobilePanel);
          if (!focusable.length) return;
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      });

      mobilePanel.querySelectorAll('a[href^="/"]').forEach((link) => {
        link.addEventListener('click', () => { toggleMobileNav(false); });
      });
    }

    if (mobileBackdrop) {
      mobileBackdrop.addEventListener('click', () => { toggleMobileNav(false); });
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && mobileNav && mobileNav.classList.contains('is-open')) {
        toggleMobileNav(false);
      }
    });

    const menus = Array.from(document.querySelectorAll('.mega-menu'));
    function closeMenus(except) {
      menus.forEach((menu) => {
        if (menu === except) return;
        menu.classList.remove('is-open');
        const trigger = menu.querySelector('[data-mega-trigger]');
        if (trigger) trigger.setAttribute('aria-expanded', 'false');
      });
    }

    menus.forEach((menu) => {
      const trigger = menu.querySelector('[data-mega-trigger]');
      if (!trigger) return;
      trigger.addEventListener('click', () => {
        const open = !menu.classList.contains('is-open');
        closeMenus(menu);
        menu.classList.toggle('is-open', open);
        trigger.setAttribute('aria-expanded', String(open));
      });
      menu.addEventListener('mouseenter', () => {
        closeMenus(menu);
        menu.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
      });
      menu.addEventListener('mouseleave', () => {
        menu.classList.remove('is-open');
        trigger.setAttribute('aria-expanded', 'false');
      });
    });

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (target && !target.closest('.mega-menu') && !target.closest('.site-search') && !target.closest('.mobile-search')) {
        closeMenus();
        document.querySelectorAll('.search-popover').forEach((el) => { el.classList.add('hidden'); });
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMenus();
    });

    const path = location.pathname.replace(/\/+$/, '') || '/';
    document.querySelectorAll('.mega-nav-link, .nav-link, .mega-item').forEach((link) => {
      const href = link.getAttribute('href');
      if (!href) return;
      try {
        const linkPath = new URL(href, location.origin).pathname.replace(/\/+$/, '') || '/';
        if (linkPath === path) {
          link.setAttribute('aria-current', 'page');
          link.classList.add('active');
        }
      } catch (error) {}
    });
  })();
</script>
