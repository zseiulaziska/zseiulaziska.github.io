  '/historia': 'clock',
  '/nasza-spolecznosc': 'users',
  '/dyrekcja': 'people',
  '/grono-pedagogiczne': 'graduation',
  '/klienci-i-partnerzy': 'briefcase',
  '/rekrutacja': 'check',
  '/kierunki': 'graduation',
  '/kierunki-ksztalcenia': 'book-open',
  '/lo-dla-doroslych': 'book',
  '/klasy-mundurowe': 'shield',
  '/klasa-policyjna': 'badge',
  '/egzaminy-zawodowe': 'award',
  '/dla-uczniow': 'graduation',
  '/dla-rodzicow': 'people',
  '/plan-lekcji': 'calendar',
  '/kalendarz': 'calendar-days',
  '/podreczniki': 'book',
  '/dokumenty-szkolne': 'file',
  '/dokumenty': 'clipboard',
  '/rodo': 'shield',
  '/projekty': 'spark',
  '/erasmus': 'globe',
  '/blog': 'news',
  '/dostepnosc': 'access',
};

const iconPaths = {
