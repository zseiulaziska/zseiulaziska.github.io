const quickLinks = [
  ['Plan lekcji', '/plan-lekcji'],
  ['Dziennik', 'https://uonetplus.vulcan.net.pl/powiatmikolowski'],
  ['Rekrutacja', '/rekrutacja'],
];

const mobileSections = [
  { title: 'Najważniejsze', links: [['Strona główna', '/'], ...quickLinks, ['Kontakt', '/kontakt']] },
  ...sections.map((section) => ({
    title: section.title,
    links: section.groups.flatMap((group) => group.links.map(([label, href]) => [label, href])),
  })),
  {
    title: 'Linki zewnętrzne',
    links: [
      ['BIP', 'https://zseiu.ssdip.bip.gov.pl/'],
      ['Facebook', 'https://www.facebook.com/zseiu'],
      ['Instagram', 'https://www.instagram.com/zseiu_laziska/'],
    ],
  },
];

const isExternal = (href: string) => href.startsWith('http');

const linkIcons = {
