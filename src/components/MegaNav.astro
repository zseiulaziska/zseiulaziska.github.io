];

const isExternal = (href: string) => href.startsWith('http');

const linkIcons = {
  '/informacje': 'info',
  '/historia': 'clock',
  '/nasza-spolecznosc': 'users',
  '/dyrekcja': 'people',
  '/grono-pedagogiczne': 'graduation',
  '/klienci-i-partnerzy': 'briefcase',
  '/rekrutacja': 'check',
  '/kierunki': 'graduation',
  '/kierunki-ksztalcenia': 'book-open',
  '/lo-dla-doroslych': 'book',
  '/klasy-mundurowe': 'shield',
  '/klasa-policyjna': 'badge',
  '/egzaminy-zawodowe': 'award',
  '/technik-elektryk': 'spark',
  '/technik-informatyk': 'terminal',
  '/technik-logistyk': 'globe',
  '/technik-organizacji-turystyki': 'globe',
  '/technik-urzadzen-i-systemow-energetyki-odnawialnej': 'spark',
  '/technik-stylista': 'book',
  '/dla-uczniow': 'graduation',
  '/dla-rodzicow': 'people',
  '/plan-zajec-lo': 'calendar',
  '/kalendarz': 'calendar-days',
  '/podreczniki': 'book',
  '/dokumenty': 'file',
  '/dokumenty': 'clipboard',
  '/rodo': 'shield',
  '/projekty': 'spark',
  '/erasmus': 'globe',
  '/blog': 'news',
  '/dostepnosc': 'access',
