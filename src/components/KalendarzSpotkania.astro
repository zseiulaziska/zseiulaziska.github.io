---
import spotkania from '../content/kalendarz/spotkania.json';

interface Spotkanie {
  date: string;
  time: string;
  timeVariant: string;
  title: string;
  description: string;
  colSpan: boolean;
}

const timeStyles: Record<string, string> = {
  blue: 'bg-blue-100 dark:bg-blue-950/60 text-blue-700 dark:text-blue-300',
  purple: 'bg-purple-100 dark:bg-purple-950/60 text-purple-700 dark:text-purple-300',
};

const meetings = spotkania.meetings as Spotkanie[];
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
  {meetings.map((m) => (
    <div class={`rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-5 transition-all duration-300 hover:shadow-md hover:border-primary-400 dark:hover:border-primary-600${m.colSpan ? ' md:col-span-2 lg:col-span-2' : ''}`}>
      <div class="flex items-center justify-between gap-2 mb-3">
        <span class="text-xl sm:text-2xl font-extrabold text-primary-600 dark:text-primary-400">{m.date}</span>
        <span class={`px-2.5 py-0.5 rounded-full text-xs font-semibold ${timeStyles[m.timeVariant] || timeStyles.blue}`}>{m.time}</span>
      </div>
      <h3 class="text-base font-bold text-slate-900 dark:text-white mb-1">{m.title}</h3>
      <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed">{m.description}</p>
    </div>
  ))}
</div>