---
---

<header class="bg-gray-50 dark:bg-navy-800 text-gray-900 dark:text-white">
  <!-- ===== TOP ROW ===== -->
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
    <!-- Left: Coats of arms -->
    <div class="hidden md:flex items-center gap-2 shrink-0">
      <!-- Center: School logo -->
      <a href="/" class="flex items-center gap-3 text-2xl font-bold tracking-tight shrink-0">
        <img src="/images/logo-szkoly-light.png" alt="Logo ZSEiU" class="h-12 w-auto dark:hidden" />
        <img src="/images/logo-szkoly-dark.png" alt="Logo ZSEiU" class="h-12 w-auto hidden dark:block" />
        <span class="hidden sm:inline">ZSEiU</span>
      </a>
      <img src="/images/Herb_Polski.svg" alt="Herb Polski" class="h-10 w-auto" />
      <img src="/images/Herb_powiatu.svg" alt="Herb powiatu" class="h-10 w-auto" />
    </div>


    <!-- Center: Quick links -->
    <div class="hidden md:flex items-center gap-1">
      <a href="#" title="Plan lekcji ZSEiU" aria-label="Plan lekcji"
        class="p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-navy-700 text-gray-600 dark:text-slate-300 hover:text-primary-500 dark:hover:text-primary-300 transition-colors">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
          <rect x="9" y="3" width="6" height="4" rx="1"/>
          <path d="M9 14l2 2 4-4"/>
        </svg>
      </a>
      <a href="/plan-lekcji" title="Plan lekcji - Liceum dla Dorosłych" aria-label="Plan lekcji - Liceum dla Dorosłych"
        class="p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-navy-700 text-gray-600 dark:text-slate-300 hover:text-primary-500 dark:hover:text-primary-300 transition-colors">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2"/>
          <path d="M16 2v4M8 2v4M3 10h18"/>
        </svg>
      </a>
      <a href="https://uonetplus.vulcan.net.pl/powiatmikolowski" target="_blank" rel="noopener noreferrer" title="Dziennik elektroniczny" aria-label="Dziennik elektroniczny"
        class="p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-navy-700 text-gray-600 dark:text-slate-300 hover:text-primary-500 dark:hover:text-primary-300 transition-colors">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
          <path d="M8 7h8M8 11h6"/>
        </svg>
      </a>
    </div>

    <!-- Right: Search + utilities -->
    <div class="flex items-center gap-3 shrink-0">
      <!-- Desktop Search (visible from lg) -->
      <div class="relative hidden lg:block">
        <div class="flex items-center">
          <svg class="absolute left-3 h-4 w-4 text-gray-400 pointer-events-none" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2" />
            <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
          <input id="search-input" type="text" placeholder="Szukaj..." autocomplete="off"
            class="w-56 pl-9 pr-3 py-2 rounded-lg border border-gray-200 dark:border-navy-600 bg-white dark:bg-navy-750 text-sm placeholder-gray-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
        </div>
        <!-- Search results -->
        <div id="search-results"
          class="hidden absolute right-0 mt-2 w-80 bg-white dark:bg-navy-750 rounded-lg shadow-xl border border-gray-100 dark:border-navy-600 z-50 max-h-96 overflow-y-auto">
        </div>
      </div>

      <!-- Theme toggle -->
      <button id="theme-toggle"
        class="p-2 rounded-lg hover:bg-gray-200 dark:hover:bg-navy-700 transition-colors" aria-label="Przełącz tryb ciemny/jasny">
        <svg class="w-5 h-5 dark:hidden" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <svg class="w-5 h-5 hidden dark:block" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>

      <!-- BIP & Social (visible from lg) -->
      <span class="hidden lg:flex items-center gap-2">
        <a href="https://zseiu.ssdip.bip.gov.pl/" target="_blank" rel="noopener noreferrer"
          class="hover:opacity-80 transition-opacity" aria-label="BIP">
          <img src="/images/bip_simple.svg" alt="BIP" class="h-5 w-auto" />
        </a>
        <a href="https://www.facebook.com/zseiu" target="_blank" rel="noopener noreferrer"
          class="hover:opacity-80 transition-opacity" aria-label="Facebook">
          <svg class="h-5 w-auto" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
          </svg>
        </a>
        <a href="https://www.instagram.com/zseiu_laziska/" target="_blank" rel="noopener noreferrer"
          class="hover:opacity-80 transition-opacity" aria-label="Instagram">
          <svg class="h-5 w-auto" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
          </svg>
        </a>
      </span>

      <!-- Mobile hamburger -->
      <details id="mobile-nav" class="md:hidden relative">
        <summary id="mobile-nav-toggle"
          class="list-none cursor-pointer flex items-center gap-2 px-3 py-2 rounded hover:bg-gray-200 dark:hover:bg-navy-700">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round" />
          </svg>
        </summary>
        <div
          class="fixed md:absolute inset-x-4 md:inset-x-auto top-[4.5rem] md:top-auto mt-0 md:mt-2 md:right-0 md:w-80 bg-white dark:bg-navy-750 rounded-lg shadow-xl ring-1 ring-black/5 z-50 max-h-[85vh] overflow-y-auto">
          <div class="p-3 border-b border-gray-100 dark:border-navy-600">
            <div class="relative">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400 pointer-events-none" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2" />
                <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              </svg>
              <input id="mobile-search-input" type="text" placeholder="Szukaj..." autocomplete="off"
                class="w-full pl-9 pr-3 py-2 rounded-lg border border-gray-200 dark:border-navy-600 bg-gray-50 dark:bg-navy-800 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
            </div>
            <div id="mobile-search-results" class="mt-2 hidden"></div>
          </div>
          <ul class="flex flex-col p-2">
            <li><a href="/" class="nav-link">Strona główna</a></li>

            <li class="border-t border-gray-100 dark:border-navy-600 mt-1 pt-2">
              <strong class="px-3 text-sm text-slate-500 dark:text-slate-400">O szkole</strong>
            </li>
            <li><a href="/informacje" class="nav-link">Informacje o szkole</a></li>
            <li><a href="/historia" class="nav-link">Historia</a></li>
            <li><a href="/dyrekcja" class="nav-link">Dyrekcja i kierownictwo</a></li>
            <li><a href="/grono-pedagogiczne" class="nav-link">Grono pedagogiczne</a></li>
            <li><a href="/nasza-spolecznosc" class="nav-link">Nasza społeczność</a></li>
            <li class="border-t border-gray-100 dark:border-navy-600 mt-1 pt-2">
              <strong class="px-3 text-sm text-slate-500 dark:text-slate-400">Edukacja</strong>
            </li>
            <li><a href="/kierunki" class="nav-link">Kierunki kształcenia</a></li>
            <li><a href="/kierunki-ksztalcenia" class="nav-link">Oferta 2025/2026</a></li>
            <li><a href="/klasy-mundurowe" class="nav-link">Klasy mundurowe</a></li>
            <li><a href="/klasa-policyjna" class="nav-link">Klasa policyjna</a></li>
            <li><a href="/podreczniki" class="nav-link">Podręczniki</a></li>
            <li class="border-t border-gray-100 dark:border-navy-600 mt-1 pt-2">
              <strong class="px-3 text-sm text-slate-500 dark:text-slate-400">Projekty i dokumenty</strong>
            </li>
            <li><a href="/projekty" class="nav-link">Projekty i Erasmus+</a></li>
            <li><a href="/erasmus" class="nav-link">Erasmus+</a></li>
            <li><a href="/dokumenty-szkolne" class="nav-link">Dokumenty szkolne</a></li>
            <li><a href="/dokumenty" class="nav-link">Dokumenty i polityki</a></li>
            <li><a href="/rodo" class="nav-link">RODO</a></li>
            <li><a href="/dostepnosc" class="nav-link">Dostępność</a></li>
            <li class="border-t border-gray-100 dark:border-navy-600 mt-1 pt-2">
              <strong class="px-3 text-sm text-slate-500 dark:text-slate-400">Uczniowie i rodzice</strong>
            </li>
            <li><a href="/dla-uczniow" class="nav-link">Dla uczniów</a></li>
            <li><a href="/dla-rodzicow" class="nav-link">Dla rodziców</a></li>
            <li><a href="/lo-dla-doroslych" class="nav-link">LO dla Dorosłych</a></li>
            <li><a href="/rekrutacja" class="nav-link">Rekrutacja</a></li>
            <li><a href="/kalendarz" class="nav-link">Kalendarz</a></li>
            <li><a href="/egzaminy-zawodowe" class="nav-link">Egzaminy zawodowe</a></li>
            <li class="border-t border-gray-100 dark:border-navy-600 mt-1 pt-2">
              <strong class="px-3 text-sm text-slate-500 dark:text-slate-400">Media</strong>
            </li>
            <li><a href="/blog" class="nav-link">Blog</a></li>
            <li class="border-t border-gray-100 dark:border-navy-600 mt-1 pt-2"><a href="/kontakt" class="nav-link">Kontakt</a></li>
            <li class="border-t border-gray-100 dark:border-navy-600 mt-1 pt-2">
              <strong class="px-3 text-sm text-slate-500 dark:text-slate-400">Linki zewnętrzne</strong>
            </li>
            <li><a href="https://zseiu.ssdip.bip.gov.pl/" target="_blank" rel="noopener noreferrer" class="nav-link"><img
                  src="/images/bip_simple.svg" alt="BIP" class="h-3 w-auto inline-block align-middle" /> BIP</a></li>
            <li><a href="https://www.facebook.com/zseiu" target="_blank" rel="noopener noreferrer" class="nav-link">
                <svg class="h-4 w-auto inline-block align-middle" viewBox="0 0 24 24" fill="currentColor"
                  aria-hidden="true">
                  <path
                    d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                </svg>
                Facebook</a></li>
            <li><a href="https://www.instagram.com/zseiu_laziska/" target="_blank" rel="noopener noreferrer"
                class="nav-link">
                <svg class="h-4 w-auto inline-block align-middle" viewBox="0 0 24 24" fill="currentColor"
                  aria-hidden="true">
                  <path
                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                </svg>
                Instagram</a></li>
          </ul>
        </div>
      </details>
    </div>
  </div>

  <!-- ===== BOTTOM ROW - Mega Menu ===== -->
  <nav class="border-t border-gray-200 dark:border-navy-700 bg-white dark:bg-navy-850 shadow-sm"
    aria-label="Główna nawigacja">
    <div class="max-w-6xl mx-auto px-4">
      <ul class="hidden md:flex items-center justify-center">
        <li><a href="/" class="mega-nav-link">Strona główna</a></li>

        <!-- O szkole -->
        <li class="relative group">
          <span class="mega-nav-link cursor-pointer select-none">
            O szkole
            <svg class="w-3 h-3 ml-1 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 24 24"
              fill="none" aria-hidden="true">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                stroke-linejoin="round" />
            </svg>
          </span>
          <div
            class="absolute left-0 top-full pt-2 invisible group-hover:visible opacity-0 group-hover:opacity-100 translate-y-1 group-hover:translate-y-0 transition-all duration-200 z-50 pointer-events-none group-hover:pointer-events-auto">
            <div
              class="bg-white dark:bg-navy-750 rounded-lg shadow-xl border border-gray-100 dark:border-navy-600 p-6 w-[720px] max-w-[90vw]">
              <div class="grid grid-cols-3 gap-5">
                <div>
                  <h3 class="text-xs font-semibold uppercase tracking-wider text-primary-600 dark:text-primary-300 mb-3">
                    O szkole</h3>
                  <ul class="space-y-3">
                    <li><a href="/informacje"
                        class="flex items-start gap-3 rounded-lg p-2 hover:bg-gray-100 dark:hover:bg-navy-700 transition-colors group">
                        <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary-500 dark:text-primary-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>
                        </svg>
                        <span class="flex flex-col">
                          <span class="text-sm font-medium text-gray-900 dark:text-slate-200 group-hover:text-primary-500 dark:group-hover:text-primary-300">Informacje o szkole</span>
                          <span class="text-xs text-gray-500 dark:text-slate-400">Podstawowe informacje i dane</span>
                        </span>
                      </a></li>
                    <li><a href="/historia"
                        class="flex items-start gap-3 rounded-lg p-2 hover:bg-gray-100 dark:hover:bg-navy-700 transition-colors group">
                        <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary-500 dark:text-primary-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                        </svg>
                        <span class="flex flex-col">
                          <span class="text-sm font-medium text-gray-900 dark:text-slate-200 group-hover:text-primary-500 dark:group-hover:text-primary-300">Historia</span>
                          <span class="text-xs text-gray-500 dark:text-slate-400">Dzieje ZSEiU w Łaziskach Górnych</span>
                        </span>
                      </a></li>
                  </ul>
                </div>
                <div>
                  <h3 class="text-xs font-semibold uppercase tracking-wider text-primary-600 dark:text-primary-300 mb-3">
                    Kierownictwo</h3>
                  <ul class="space-y-3">
                    <li><a href="/dyrekcja"
                        class="flex items-start gap-3 rounded-lg p-2 hover:bg-gray-100 dark:hover:bg-navy-700 transition-colors group">
                        <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary-500 dark:text-primary-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
                        </svg>
                        <span class="flex flex-col">
                          <span class="text-sm font-medium text-gray-900 dark:text-slate-200 group-hover:text-primary-500 dark:group-hover:text-primary-300">Dyrekcja i kierownictwo</span>
                          <span class="text-xs text-gray-500 dark:text-slate-400">Władze i zarząd szkoły</span>
                        </span>
                      </a></li>
                    <li><a href="/grono-pedagogiczne"
                        class="flex items-start gap-3 rounded-lg p-2 hover:bg-gray-100 dark:hover:bg-navy-700 transition-colors group">
                        <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary-500 dark:text-primary-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>
                        </svg>
                        <span class="flex flex-col">
                          <span class="text-sm font-medium text-gray-900 dark:text-slate-200 group-hover:text-primary-500 dark:group-hover:text-primary-300">Grono pedagogiczne</span>
                          <span class="text-xs text-gray-500 dark:text-slate-400">Nauczyciele i pracownicy</span>
                        </span>
                      </a></li>
                  </ul>
                </div>
                <div>
                  <h3 class="text-xs font-semibold uppercase tracking-wider text-primary-600 dark:text-primary-300 mb-3">
                    Społeczność</h3>
                  <ul class="space-y-3">
                    <li><a href="/nasza-spolecznosc"
                        class="flex items-start gap-3 rounded-lg p-2 hover:bg-gray-100 dark:hover:bg-navy-700 transition-colors group">
                        <svg class="mt-0.5 h-5 w-5 shrink-0 text-primary-500 dark:text-primary-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
                        </svg>
                        <span class="flex flex-col">
                          <span class="text-sm font-medium text-gray-900 dark:text-slate-200 group-hover:text-primary-500 dark:group-hover:text-primary-300">Nasza społeczność</span>
                          <span class="text-xs text-gray-500 dark:text-slate-400">Życie i wydarzenia szkolne</span>
                        </span>
                      </a></li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </li>

        <!-- Edukacja -->
        <li class="relative group">
