        <li class="border-t border-gray-100 dark:border-slate-700 mt-1 pt-2"><strong class="px-3 text-sm text-slate-500">O szkole</strong></li>
        <li><a href="/informacje" class="nav-link block px-3 py-2 rounded hover:bg-gray-50 dark:hover:bg-slate-700">Informacje o szkole</a></li>
