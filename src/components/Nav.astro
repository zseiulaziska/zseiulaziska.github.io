              <div class="grid grid-cols-2 gap-6">
                <div>
                  <h3 class="text-xs font-semibold uppercase tracking-wider text-primary-500 dark:text-primary-300 mb-3">
                    Projekty</h3>
                  <ul class="space-y-2">
                    <li><a href="/projekty"
