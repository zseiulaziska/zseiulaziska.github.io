  <script>
    // Close other details menus when one is opened
    window.closeOtherDetails = (currentDetails) => {
      document.querySelectorAll('details').forEach((d) => {
        if (d !== currentDetails) d.removeAttribute('open');
      });
    };

    // Dark mode toggle
    (function() {
      try {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        const storageKey = 'theme';
        btn.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem(storageKey, isDark ? 'dark' : 'light');
        });
      } catch (e) { /* non-fatal */ }
    })();

    // Small client-side enhancement: close mobile details menu after clicking a link
    (function () {
      try {
        const details = document.getElementById('mobile-nav');
        if (!details) return;
        const links = details.querySelectorAll('a.nav-link');
        links.forEach(a => a.addEventListener('click', () => { details.open = false; }));

        // Mark active link based on current pathname
        const allNavLinks = document.querySelectorAll('a[href]');
        const path = location.pathname.replace(/\/+$/, '') || '/';
        allNavLinks.forEach(a => {
          try {
            const href = new URL(a.href, location.origin).pathname.replace(/\/+$/, '') || '/';
            if (href === path) {
              a.setAttribute('aria-current', 'page');
              a.classList.add('font-semibold');
            }
          } catch (e) {
            // ignore invalid hrefs
          }
        });
      } catch (e) {
        // non-fatal
      }
    })();
  </script>
