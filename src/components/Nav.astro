<script>
  (function () {
    // ===== SEARCH =====
    try {
      const searchInput = document.getElementById('search-input');
      const searchResults = document.getElementById('search-results');
      const mobileSearchInput = document.getElementById('mobile-search-input');
      const mobileSearchResults = document.getElementById('mobile-search-results');

      let searchIndex = [];

      fetch('/api/search.json')
        .then(function (r) { return r.json(); })
        .then(function (data) { searchIndex = data; })
        .catch(function () { });

      function escapeRegExp(str) {
        return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      }

      function highlightMatch(text, query) {
        var regex = new RegExp('(' + escapeRegExp(query) + ')', 'gi');
        return text.replace(regex, '<mark>$1</mark>');
      }

      function performSearch(query, resultsContainer) {
        var q = query.trim().toLowerCase();
        if (q.length < 2) {
          resultsContainer.classList.add('hidden');
          return;
        }

        var results = searchIndex.filter(function (item) {
          return item.title.toLowerCase().indexOf(q) !== -1 ||
            (item.description && item.description.toLowerCase().indexOf(q) !== -1) ||
            (item.body && item.body.toLowerCase().indexOf(q) !== -1);
        }).slice(0, 8);

        if (results.length === 0) {
          resultsContainer.innerHTML =
            '<div class="px-4 py-3 text-sm text-gray-500 dark:text-slate-400">Brak wyników</div>';
          resultsContainer.classList.remove('hidden');
          return;
        }

        var html = '';
        results.forEach(function (item) {
          var title = highlightMatch(item.title, q);
          var snippet = item.description || '';
          if (item.body && !snippet.toLowerCase().includes(q)) {
            var idx = item.body.toLowerCase().indexOf(q);
            var start = Math.max(0, idx - 60);
            var end = Math.min(item.body.length, idx + q.length + 100);
            snippet = (start > 0 ? '…' : '') + item.body.substring(start, end) + (end < item.body.length ? '…' : '');
          }
          var desc = highlightMatch(snippet, q);
          html += '<a href="' + item.url +
            '" class="search-result-item"><span class="text-sm font-medium">' +
            title + '</span><span class="text-xs text-gray-500 dark:text-slate-400 block mt-0.5">' +
            desc + '</span></a>';
        });

        resultsContainer.innerHTML = html;
        resultsContainer.classList.remove('hidden');
      }

      function setupSearch(input, results) {
        if (!input || !results) return;

        input.addEventListener('input', function () {
          performSearch(this.value, results);
        });

        input.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') {
            results.classList.add('hidden');
            this.blur();
          }
          var items = results.querySelectorAll('a');
          if (items.length === 0) return;
          var currentIndex = Array.from(items).indexOf(document.activeElement);
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            var next = currentIndex + 1 < items.length ? currentIndex + 1 : 0;
            items[next].focus();
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            var prev = currentIndex - 1 >= 0 ? currentIndex - 1 : items.length - 1;
            items[prev].focus();
          }
        });

        document.addEventListener('click', function (e) {
          if (!input.contains(e.target) && !results.contains(e.target)) {
            results.classList.add('hidden');
          }
        });
      }

      setupSearch(searchInput, searchResults);
      setupSearch(mobileSearchInput, mobileSearchResults);
    } catch (e) { /* non-fatal */ }

    // ===== DARK MODE =====
    try {
      var btn = document.getElementById('theme-toggle');
      if (btn) {
        btn.addEventListener('click', function () {
          var isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      }
    } catch (e) { /* non-fatal */ }

    // ===== MOBILE NAV CLOSE ON LINK CLICK =====
    try {
      var details = document.getElementById('mobile-nav');
      if (details) {
        var mobileLinks = details.querySelectorAll('a');
        mobileLinks.forEach(function (a) {
          // Only close for internal links
          if (a.getAttribute('href') && a.getAttribute('href').startsWith('/')) {
            a.addEventListener('click', function () { details.open = false; });
          }
        });
      }
    } catch (e) { /* non-fatal */ }

    // ===== ACTIVE LINK HIGHLIGHTING =====
    try {
      var path = location.pathname.replace(/\/+$/, '') || '/';
      var allNavLinks = document.querySelectorAll('.mega-nav-link, .nav-link');
      allNavLinks.forEach(function (a) {
        try {
          var href = a.getAttribute('href');
          if (!href) return;
          var linkPath = new URL(href, location.origin).pathname.replace(/\/+$/, '') || '/';
          if (linkPath === path) {
            a.setAttribute('aria-current', 'page');
            a.classList.add('active');
          }
        } catch (e) { /* ignore */ }
      });
    } catch (e) { /* non-fatal */ }

    // ===== CLOSE MEGA MENUS ON ESCAPE =====
    try {
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
          // close search results if open
          var sr = document.getElementById('search-results');
          if (sr) sr.classList.add('hidden');
        }
      });
    } catch (e) { /* non-fatal */ }
  })();
</script>
