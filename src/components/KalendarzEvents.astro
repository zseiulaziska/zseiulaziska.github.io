---
import type { InferEntrySchema } from 'astro:content';
import eventsData from '../content/kalendarz/events.json';

interface CalendarEvent {
  date: string;
  category: string;
  badgeLabel: string;
  badgeIcon: string;
  badgeVariant: string;
  title: string;
  description: string;
}

const badgeStyles: Record<string, string> = {
  emerald: 'bg-emerald-100 dark:bg-emerald-950/60 text-emerald-700 dark:text-emerald-300 border-emerald-200 dark:border-emerald-800',
  blue: 'bg-blue-100 dark:bg-blue-950/60 text-blue-700 dark:text-blue-300 border-blue-200 dark:border-blue-800',
  amber: 'bg-amber-100 dark:bg-amber-950/60 text-amber-700 dark:text-amber-300 border-amber-200 dark:border-amber-800',
  cyan: 'bg-cyan-100 dark:bg-cyan-950/60 text-cyan-700 dark:text-cyan-300 border-cyan-200 dark:border-cyan-800',
  purple: 'bg-purple-100 dark:bg-purple-950/60 text-purple-700 dark:text-purple-300 border-purple-200 dark:border-purple-800',
  indigo: 'bg-indigo-100 dark:bg-indigo-950/60 text-indigo-700 dark:text-indigo-300 border-indigo-200 dark:border-indigo-800',
};

const badgeIcons: Record<string, string> = {
  calendar: 'M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6',
  clock: 'M12 6v6l4 2M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z',
  'arrow-right': 'M5 12h14M12 5l7 7-7 7',
  diamond: 'M22 10 12 5 2 10l10 5 10-5z',
  crosshair: 'M2 12h20M12 2v20',
  circle: 'M12 12m-10 0a10 10 0 1 0 20 0a10 10 0 1 0-20 0',
  clipboard: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z',
  check: 'M20 6 9 17l-5-5',
};

const events = eventsData.events as CalendarEvent[];
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12" id="dates-grid">
  {events.map((event) => (
    <div
      class="event-card date-item rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-5 transition-all duration-300 hover:shadow-md hover:border-primary-400 dark:hover:border-primary-600"
      data-category={event.category}
    >
      <div class="flex items-start justify-between gap-3 mb-2">
        <span class="text-2xl sm:text-3xl font-extrabold text-primary-600 dark:text-primary-400 tracking-tight">{event.date}</span>
        <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-bold ${badgeStyles[event.badgeVariant] || badgeStyles.emerald} shrink-0`}>
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d={badgeIcons[event.badgeIcon] || badgeIcons.calendar} />
          </svg>
          {event.badgeLabel}
        </span>
      </div>
      <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">{event.title}</h3>
      <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed">{event.description}</p>
    </div>
  ))}
</div>