---
<section id="kierunki" class="reveal py-12 bg-white dark:bg-navy-950">
  <div class="container max-w-6xl mx-auto p-4">
    <h2 class="text-3xl font-bold mb-8 text-slate-900 dark:text-white text-center">Nasze kierunki kształcenia</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { title: 'Technik informatyk', icon: 'M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z' },
        { title: 'Technik elektryk', icon: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z' },
        { title: 'Technik logistyk', icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4' },
        { title: 'Technik organizacji turystyki', icon: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z' },
        { title: 'Technik stylista', icon: 'M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z' },
        { title: 'Technik urządzeń i systemów OZE', icon: 'M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83' },
        { title: 'Mechanik - monter maszyn', icon: 'M12 2l4 4-4 4 4 4-4 4M6 6l4 4-4 4 4 4-4 4' },
        { title: 'Operator maszyn do przetwórstwa tworzyw', icon: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z' },
        { title: 'Klasy wielozawodowe', icon: 'M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.42a12.08 12.08 0 0 1 1.84 3.42M12 14l-6.16-3.42a12.08 12.08 0 0 0-1.84 3.42M12 14v9' }
      ].map((kierunek) => (
        <div class="reveal p-6 bg-slate-50 dark:bg-navy-800 rounded-xl border border-slate-100 dark:border-navy-600 shadow-sm flex items-center gap-4 hover:border-primary-500 transition cursor-pointer">
          <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-primary-100 dark:bg-navy-700 text-primary-500 dark:text-primary-300 shrink-0">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={kierunek.icon} />
            </svg>
          </div>
          <h3 class="font-semibold text-slate-900 dark:text-white">{kierunek.title}</h3>
        </div>
      ))}
    </div>
  </div>
</section>
