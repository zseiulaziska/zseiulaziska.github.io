---
export interface Props {
  year: string;
  side?: 'left' | 'right';
  highlight?: boolean;
}

const { year, side = 'right', highlight = false } = Astro.props;
---

<div
  class="timeline-event opacity-0 transition-all duration-700 ease-out relative pl-16 md:pl-0 mb-12 md:mb-16 motion-reduce:opacity-100 motion-reduce:translate-x-0"
  class:list={{
    'md:opacity-0 md:translate-x-8 md:motion-reduce:opacity-100 md:motion-reduce:translate-x-0': side === 'right',
    'md:opacity-0 md:-translate-x-8 md:motion-reduce:opacity-100 md:motion-reduce:translate-x-0': side === 'left',
    'opacity-100 translate-x-0': false,
  }}
>
  <!-- Mobile dot + line -->
  <div class="md:hidden absolute left-0 top-0 bottom-0 w-0.5 bg-primary-200 dark:bg-primary-700/50"></div>
  <div class="md:hidden absolute -left-1.25 top-1.5 w-3 h-3 rounded-full bg-primary-500 ring-4 ring-white dark:ring-navy-900 z-10"></div>

  <div class="md:flex md:items-start md:gap-8 lg:gap-12">
    <!-- Year badge -->
    <div
      class="shrink-0 md:w-40 lg:w-48 text-left mb-3 md:mb-0 md:text-right"
      class:list={{
        'md:order-1': side === 'right',
        'md:order-1 md:text-left': side === 'left',
      }}
    >
      <span
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-bold tracking-wide"
        class:list={{
          'bg-primary-100 text-primary-700 dark:bg-primary-700/30 dark:text-primary-300 shadow-sm': highlight,
          'bg-slate-100 text-slate-600 dark:bg-navy-800 dark:text-slate-400': !highlight,
        }}
      >
        {highlight ? <span class="w-1.5 h-1.5 rounded-full bg-primary-500"></span> : null}
        {year}
      </span>
    </div>

    <!-- Desktop dot on the center line -->
    <div class="hidden md:flex relative shrink-0 w-10 items-start justify-center">
      <div class="w-4 h-4 rounded-full border-2 z-10 mt-1.5 transition-colors duration-300" class:list={{
        'border-primary-500 bg-primary-100 dark:bg-primary-700/30 shadow-md': highlight,
        'border-slate-300 bg-white dark:border-navy-500 dark:bg-navy-800': !highlight,
      }}></div>
    </div>

    <!-- Content card -->
    <div
      class="flex-1 min-w-0"
      class:list={{
        'md:order-3': side === 'right',
        'md:order-1': side === 'left',
      }}
    >
      <div
        class="p-5 md:p-6 lg:p-7 rounded-2xl bg-white dark:bg-navy-800/90 border-2 transition-all duration-300 cursor-pointer"
        class:list={{
          'border-primary-100 dark:border-primary-700/40 shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.03),4px_4px_12px_rgba(0,0,0,0.06)] hover:shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.03),6px_6px_20px_rgba(0,0,0,0.1)]': true,
          'hover:border-primary-200 dark:hover:border-primary-700': highlight,
          'hover:border-slate-200 dark:hover:border-navy-500': !highlight
        }}
        tabindex="0"
        role="article"
      >
        <slot />
      </div>
    </div>
  </div>
</div>
