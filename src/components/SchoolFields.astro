---
import schoolGroups from '../content/field/school-groups.json';

interface FieldItem {
  name: string;
  note?: string;
  slug: string;
  colSpan?: boolean;
}

interface SchoolGroup {
  name: string;
  years?: string;
  fields: FieldItem[];
}

export type Variant = 'detailed' | 'compact';

const { groups = schoolGroups, variant = 'detailed' }: { groups?: SchoolGroup[]; variant?: Variant } = Astro.props;

// Group visual configuration for infographic styling
const groupThemes: Record<string, {
  category: string;
  gradient: string;
  border: string;
  badgeBg: string;
  badgeText: string;
  iconBg: string;
}> = {
  "Technikum Nr 1": {
    category: "Technikum",
    gradient: "from-blue-600 via-primary-600 to-cyan-600 dark:from-blue-700 dark:via-primary-700 dark:to-cyan-700",
    border: "border-primary-200 dark:border-primary-800/50",
    badgeBg: "bg-blue-100 dark:bg-blue-950/60",
    badgeText: "text-blue-700 dark:text-blue-300",
    iconBg: "bg-blue-500/10 text-blue-600 dark:text-blue-400",
  },
  "Branżowa Szkoła I stopnia": {
    category: "Szkoła Branżowa I st.",
    gradient: "from-emerald-600 via-teal-600 to-green-600 dark:from-emerald-700 dark:via-teal-700 dark:to-green-700",
    border: "border-emerald-200 dark:border-emerald-800/50",
    badgeBg: "bg-emerald-100 dark:bg-emerald-950/60",
    badgeText: "text-emerald-700 dark:text-emerald-300",
    iconBg: "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400",
  },
  "Branżowa Szkoła I stopnia - klasa wielozawodowa": {
    category: "Klasa Wielozawodowa",
    gradient: "from-amber-600 via-orange-600 to-amber-700 dark:from-amber-700 dark:via-orange-700 dark:to-amber-800",
    border: "border-amber-200 dark:border-amber-800/50",
    badgeBg: "bg-amber-100 dark:bg-amber-950/60",
    badgeText: "text-amber-800 dark:text-amber-300",
    iconBg: "bg-amber-500/10 text-amber-600 dark:text-amber-400",
  },
  "Branżowa Szkoła II stopnia": {
    category: "Szkoła Branżowa II st.",
    gradient: "from-purple-600 via-indigo-600 to-purple-700 dark:from-purple-700 dark:via-indigo-700 dark:to-purple-800",
    border: "border-purple-200 dark:border-purple-800/50",
    badgeBg: "bg-purple-100 dark:bg-purple-950/60",
    badgeText: "text-purple-700 dark:text-purple-300",
    iconBg: "bg-purple-500/10 text-purple-600 dark:text-purple-400",
  },
  "LO dla Dorosłych": {
    category: "Liceum dla Dorosłych",
    gradient: "from-indigo-600 via-slate-700 to-blue-800 dark:from-indigo-700 dark:via-slate-800 dark:to-blue-900",
    border: "border-indigo-200 dark:border-indigo-800/50",
    badgeBg: "bg-indigo-100 dark:bg-indigo-950/60",
    badgeText: "text-indigo-700 dark:text-indigo-300",
    iconBg: "bg-indigo-500/10 text-indigo-600 dark:text-indigo-400",
  }
};

const renderedGroups = groups.filter(g => g.name !== "Branżowa Szkoła I stopnia - klasa wielozawodowa");
const totalFieldsCount = renderedGroups.reduce((acc, g) => acc + g.fields.length, 0);

// Known pages mapping
const knownPages: Record<string, string> = {
  "technik-elektryk": "/technik-elektryk",
  "technik-informatyk": "/technik-informatyk",
  "technik-logistyk": "/technik-logistyk",
  "technik-organizacji-turystyki": "/technik-organizacji-turystyki",
  "technik-stylista": "/technik-stylista",
  "technik-oze": "/technik-urzadzen-i-systemow-energetyki-odnawialnej",
  "opw": "/opw",
  "opm": "/opm",
  "lo-profil-ogolny": "/lo-dla-doroslych",
  "wielozawodowa": "/wielozawodowa"
};

const visibleNoteParts = (note: string) => note.split('|').flatMap((part) => part.split('·')).map((part) => part.trim()).filter((part) => part && !/^\d+$/.test(part));
---

{variant === 'detailed' && (
  <div class="school-fields not-prose space-y-10 my-8 w-full min-w-0 text-slate-900 dark:text-white">
    <!-- INFOGRAPHIC SUMMARY STATS BAR -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 p-4 sm:p-6 rounded-2xl bg-white dark:bg-navy-800/80 border border-slate-200 dark:border-navy-700 shadow-sm text-center">
      <div class="p-3 rounded-xl bg-slate-50 dark:bg-navy-700/50">
        <span class="block text-2xl sm:text-3xl font-extrabold text-primary-600 dark:text-primary-400">{groups.length}</span>
        <span class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 font-medium">Typy Szkół</span>
      </div>
      <div class="p-3 rounded-xl bg-slate-50 dark:bg-navy-700/50">
        <span class="block text-2xl sm:text-3xl font-extrabold text-emerald-600 dark:text-emerald-400">{totalFieldsCount}</span>
        <span class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 font-medium">Kierunków & Zawodów</span>
      </div>
      <div class="p-3 rounded-xl bg-slate-50 dark:bg-navy-700/50">
        <span class="block text-2xl sm:text-3xl font-extrabold text-amber-600 dark:text-amber-400">580+</span>
        <span class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 font-medium">Uczniów i słuchaczy</span>
      </div>
      <div class="p-3 rounded-xl bg-slate-50 dark:bg-navy-700/50">
        <span class="block text-2xl sm:text-3xl font-extrabold text-purple-600 dark:text-purple-400">100%</span>
        <span class="text-xs sm:text-sm text-slate-600 dark:text-slate-400 font-medium">Skutecznej nauki</span>
      </div>
    </div>

    <!-- INFOGRAPHIC GROUPS -->
    <div class="space-y-8">
      {renderedGroups.map((group) => {
        const theme = groupThemes[group.name] || {
          category: group.name,
          gradient: "from-slate-700 to-slate-900",
          border: "border-slate-200 dark:border-slate-700",
          badgeBg: "bg-slate-100 dark:bg-slate-800",
          badgeText: "text-slate-700 dark:text-slate-300",
          iconBg: "bg-slate-500/10 text-slate-600 dark:text-slate-400",
        };

        return (
          <div class={`overflow-hidden rounded-2xl bg-white dark:bg-navy-800/80 border ${theme.border} shadow-md transition-all duration-300 hover:shadow-xl group/card`}>
            <!-- Group Header Banner -->
            <div class={`px-5 sm:px-6 py-4 sm:py-5 bg-linear-to-r ${theme.gradient} text-white flex flex-wrap items-center justify-between gap-3`}>
              <div class="flex items-center gap-3 min-w-0">
                <span class="p-2 rounded-lg bg-white/10 backdrop-blur-sm shrink-0">
                  <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 14l9-5-9-5-9 5 9 5z"></path>
                    <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0112 20.055a11.952 11.952 0 01-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path>
                  </svg>
                </span>
                <div class="min-w-0">
                  <h3 class="text-lg sm:text-2xl font-bold tracking-tight text-white leading-tight wrap-break-word">{group.name}</h3>
                  <span class="text-xs sm:text-sm text-white/80 font-medium">{theme.category}</span>
                </div>
              </div>
              {group.years && (
                <span class="px-3 py-1 rounded-full text-xs font-extrabold bg-white/20 backdrop-blur-md text-white border border-white/30 shrink-0">
                  ⏱️ {group.years}
                </span>
              )}
            </div>

            <!-- Fields Grid inside group -->
            <div class="p-4 sm:p-6">
              <div class={`grid gap-3 ${group.fields.length > 6 ? 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3' : 'grid-cols-1 sm:grid-cols-2'}`}>
                {group.fields.map((field) => {
                  const targetPage = knownPages[field.slug];
                  const TagComponent = targetPage ? 'a' : 'div';
                  const linkProps = targetPage ? { href: targetPage } : {};

                  return (
                    <TagComponent
                      {...linkProps}
                      class={`p-3.5 rounded-xl border border-slate-100 dark:border-navy-700/60 bg-slate-50/70 dark:bg-navy-900/40 hover:bg-white dark:hover:bg-navy-750 transition-all duration-200 flex flex-col justify-between min-w-0${field.colSpan ? ' md:col-span-2 lg:col-span-2' : ''} ${targetPage ? 'hover:border-primary-400 dark:hover:border-primary-500 hover:shadow-sm cursor-pointer group/field' : ''}`}
                    >
                      <div class="flex items-start gap-2.5">
                        <span class={`mt-0.5 p-1.5 rounded-md ${theme.iconBg} shrink-0`}>
                          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                          </svg>
                        </span>
                        <div class="min-w-0 flex-1">
                          <span class="font-semibold text-slate-900 dark:text-white text-sm sm:text-base leading-snug block wrap-break-word">
                            {field.name}
                          </span>
                          {field.note && visibleNoteParts(field.note).length > 0 && (
                            <div class="mt-1.5 flex flex-wrap gap-1">
                              {visibleNoteParts(field.note).map(part => (
                                <span class={`inline-block px-2 py-0.5 rounded text-[11px] font-mono font-medium ${part.toLowerCase().includes('opw') || part.toLowerCase().includes('woj') || part.toLowerCase().includes('policja') ? 'bg-red-100 text-red-700 dark:bg-red-950/60 dark:text-red-300' : part.toLowerCase().includes('oze') ? 'bg-green-100 text-green-700 dark:bg-green-950/60 dark:text-green-300' : theme.badgeBg + ' ' + theme.badgeText}`}>
                                  {part}
                                </span>
                              ))}
                            </div>
                          )}
                        </div>
                      </div>

                      {targetPage && (
                        <div class="mt-2.5 pt-2 border-t border-slate-200/60 dark:border-navy-700/60 flex items-center justify-end text-xs font-semibold text-primary-600 dark:text-primary-400 group-hover/field:translate-x-1 transition-transform">
                          <span>Zobacz szczegóły</span>
                          <svg class="w-3.5 h-3.5 ml-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-6-6 6 6-6 6"></path></svg>
                        </div>
                      )}
                    </TagComponent>
                  );
                })}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
)}

{variant === 'compact' && (
  <div class="my-6 space-y-4 not-prose w-full min-w-0 text-slate-900 dark:text-white">
    {renderedGroups.map((group) => {
      const theme = groupThemes[group.name] || {
        category: group.name,
        badgeBg: "bg-slate-100 dark:bg-slate-800",
        badgeText: "text-slate-700 dark:text-slate-300",
        iconBg: "bg-slate-500/10 text-slate-600 dark:text-slate-400",
      };

      return (
        <div class="rounded-xl border border-slate-200 dark:border-navy-700 bg-white dark:bg-navy-800/90 overflow-hidden shadow-sm">
          <div class="px-4 py-3 bg-slate-50 dark:bg-navy-750 border-b border-slate-200 dark:border-navy-700 flex items-center justify-between gap-2">
            <h3 class="font-bold text-slate-900 dark:text-white text-base flex items-center gap-2 min-w-0">
              <span class="w-2.5 h-2.5 rounded-full bg-primary-500 shrink-0"></span>
              <span class="truncate">{group.name}</span>
            </h3>
            {group.years && (
              <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-slate-200/80 dark:bg-navy-600 text-slate-700 dark:text-slate-300 shrink-0">
                {group.years}
              </span>
            )}
          </div>
          <div class="p-3 sm:p-4">
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {group.fields.map((f) => {
                const targetPage = knownPages[f.slug];
                return (
                  <li class="flex items-start gap-2 text-sm text-slate-700 dark:text-slate-300 p-1.5 rounded hover:bg-slate-50 dark:hover:bg-navy-700/50">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-500 shrink-0"></span>
                    <div class="min-w-0 flex-1">
                      {targetPage ? (
                        <a href={targetPage} class="font-semibold text-primary-600 dark:text-primary-400 hover:underline inline-flex items-center gap-1">
                          {f.name}
                          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-6-6 6 6-6 6"></path></svg>
                        </a>
                      ) : (
                        <strong class="font-semibold text-slate-900 dark:text-white">{f.name}</strong>
                      )}
                      {f.note && visibleNoteParts(f.note).length > 0 && <span class="text-xs text-slate-500 dark:text-slate-400 ml-1">({visibleNoteParts(f.note).join(' · ')})</span>}
                    </div>
                  </li>
                );
              })}
            </ul>
          </div>
        </div>
      );
    })}
  </div>
)}

<style is:global>
  html.high-contrast .school-fields,
  html.high-contrast .school-fields * {
    background: #000 !important;
    border-color: #fff !important;
    box-shadow: none !important;
    color: #fff !important;
    text-shadow: none !important;
  }

  html.high-contrast .school-fields a {
    color: #ffff00 !important;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }
</style>
