---

<section class="relative w-full min-h-[90vh] flex items-center overflow-hidden bg-navy-950">
  <div class="absolute inset-0">
    <img src="/images/333_mundurowi.jpg" alt="Uczniowie ZSEiU" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-950/80 to-navy-950/60"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-navy-950/40 via-transparent to-transparent"></div>
  </div>

  <div class="relative z-10 w-full">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="max-w-2xl">
        <p class="inline-flex items-center gap-2 text-sm font-medium text-primary-300 bg-white/10 backdrop-blur-sm px-4 py-1.5 rounded-full border border-white/10">Nowoczesne kształcenie • Praktyka • Partnerstwa</p>
        <h1 class="mt-8 text-4xl sm:text-5xl lg:text-6xl font-display font-extrabold text-white leading-tight">Zespół Szkół Energetycznych i&nbsp;Usługowych</h1>
        <p class="mt-3 text-2xl sm:text-3xl font-display font-light text-primary-200 italic">Twoja droga do zawodu</p>
        <p class="mt-6 text-lg text-slate-300 max-w-xl leading-relaxed">Łączymy teorię z praktyką — nowoczesne pracownie, programy międzynarodowe i ścisła współpraca z branżą.</p>

        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/rekrutacja" class="inline-flex items-center px-8 py-3.5 bg-primary-500 text-white font-semibold rounded-lg shadow-lg shadow-primary-500/25 hover:bg-primary-700 hover:shadow-primary-700/25 transition-all duration-200 cursor-pointer">Rozpocznij rekrutację</a>
          <a href="/informacje" class="inline-flex items-center px-8 py-3.5 border border-white/20 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors duration-200 cursor-pointer backdrop-blur-sm">Dowiedz się więcej</a>
        </div>

        <div class="mt-16 flex flex-wrap items-center gap-8 text-sm text-slate-400">
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-primary-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.1 2.7 2 6 2s6-.9 6-2v-5"/></svg>
            ~520 uczniów
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-primary-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            ~57 nauczycieli
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-5 h-5 text-primary-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
            22 oddziały
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
