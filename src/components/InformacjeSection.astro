---
---

<section class="py-20 lg:py-28 bg-navy-950">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      <!-- Left Column: Content -->
      <div class="space-y-8">

        <!-- Badge -->
        <span class="text-blue-500 font-bold text-sm uppercase tracking-wider">O szkole</span>

        <!-- Headline -->
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-white leading-tight">
          Informacje<br class="hidden sm:block" /> o ZSEiU
        </h2>

        <!-- Subheadline -->
        <p class="text-lg text-slate-400 leading-relaxed max-w-xl">
          Zespół Szkół Energetycznych i Usługowych w Łaziskach Górnych to nowoczesna, dynamicznie rozwijająca się placówka oświatowa z ponad 80-letnią tradycją.
        </p>

        <!-- Our Mission -->
        <div>
          <h3 class="text-xl font-bold text-white mb-4">Nasza misja</h3>
          <p class="text-slate-400 leading-relaxed mb-4">
            Kształcimy profesjonalistów, łącząc teorię z praktyką. Przygotowujemy uczniów do wyzwań współczesnego rynku pracy, rozwijając ich kompetencje zawodowe i osobiste.
          </p>
          <p class="text-slate-400 leading-relaxed">
            Stawiamy na nowoczesne metody nauczania, współpracę z wiodącymi firmami branżowymi oraz międzynarodowe programy wymiany. Naszym priorytetem jest sukces każdego ucznia.
          </p>
        </div>

        <!-- Divider -->
        <hr class="border-t border-slate-800" />

        <!-- The Numbers -->
        <div>
          <h3 class="text-xl font-bold text-white mb-6">Liczby</h3>
          <div class="grid grid-cols-2 gap-8">
            <div>
              <p class="text-4xl font-bold text-white">80+</p>
              <p class="text-sm text-slate-400">Lat tradycji</p>
            </div>
            <div>
              <p class="text-4xl font-bold text-white">~520</p>
              <p class="text-sm text-slate-400">Uczniów</p>
            </div>
            <div>
              <p class="text-4xl font-bold text-white">57</p>
              <p class="text-sm text-slate-400">Nauczycieli</p>
            </div>
            <div>
              <p class="text-4xl font-bold text-white">9</p>
              <p class="text-sm text-slate-400">Kierunków</p>
            </div>
          </div>
        </div>

      </div>

      <!-- Right Column: Image Gallery -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Top left - landscape -->
        <div class="rounded-2xl overflow-hidden border border-white/10">
          <img
            src="/images/info1.jpg"
            alt="Budynek ZSEiU"
            class="w-full h-full object-cover aspect-[4/3]"
            loading="lazy"
          />
        </div>
        <!-- Top right - portrait -->
        <div class="rounded-2xl overflow-hidden border border-white/10">
          <img
            src="/images/info2.jpg"
            alt="Uczniowie ZSEiU podczas zajęć"
            class="w-full h-full object-cover aspect-[3/4]"
            loading="lazy"
          />
        </div>
        <!-- Bottom left - landscape -->
        <div class="rounded-2xl overflow-hidden border border-white/10">
          <img
            src="/images/info3.jpg"
            alt="Pracownia w ZSEiU"
            class="w-full h-full object-cover aspect-[4/3]"
            loading="lazy"
          />
        </div>
        <!-- Bottom right - portrait -->
        <div class="rounded-2xl overflow-hidden border border-white/10">
          <img
            src="/images/info4.jpg"
            alt="Wydarzenie w ZSEiU"
            class="w-full h-full object-cover aspect-[3/4]"
            loading="lazy"
          />
        </div>
      </div>

    </div>
  </div>
</section>
