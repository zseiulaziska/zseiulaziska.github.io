---
---

<footer aria-label="Nawigacja w stopce" class="bg-gray-100 dark:bg-navy-950 border-t border-gray-200 dark:border-navy-800 text-slate-600 dark:text-slate-400">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-3 gap-8">
      <!-- About + Social -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/logo-szkoly-light.png" alt="Logo ZSEiU" class="h-12 w-auto dark:hidden" loading="lazy" />
          <img src="/images/logo-szkoly-dark.png" alt="Logo ZSEiU" class="h-12 w-auto hidden dark:block" loading="lazy" />
          <div>
            <h3 class="font-bold text-slate-900 dark:text-white">ZSEiU w Łaziskach Górnych</h3>
          </div>
        </div>
        <p class="text-sm">Zespół Szkół Energetycznych i Usługowych<br>ul. Chopina 11b<br>43-170 Łaziska Górne</p>
        <div class="flex items-center gap-3 mt-4" aria-label="Linki społecznościowe i BIP">
          <a href="https://zseiu.ssdip.bip.gov.pl/" target="_blank" rel="noopener noreferrer"
            class="hover:opacity-80 transition-opacity" aria-label="BIP">
            <img src="/images/bip_simple.svg" alt="BIP" class="h-5 w-auto" loading="lazy" />
          </a>
          <a href="https://www.facebook.com/zseiu" target="_blank" rel="noopener noreferrer"
            class="text-slate-500 hover:text-primary-500 transition-colors" aria-label="Facebook">
            <svg class="h-5 w-auto" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
          <a href="https://www.instagram.com/zseiu_laziska/" target="_blank" rel="noopener noreferrer"
            class="text-slate-500 hover:text-primary-500 transition-colors" aria-label="Instagram">
            <svg class="h-5 w-auto" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-bold text-slate-900 dark:text-white mb-4">Kontakt</h3>
        <ul class="text-sm space-y-2">
          <li>Tel: <a href="tel:+48322242415" class="hover:text-primary-500 transition-colors">32 224 24 15</a></li>
          <li>Email: <a href="mailto:sekretariat@zseiulaziska.pl" class="hover:text-primary-500 transition-colors">sekretariat@zseiulaziska.pl</a></li>
          <li>Godziny pracy: 7:30–15:00</li>
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-bold text-slate-900 dark:text-white mb-4">Przydatne linki</h3>
        <ul class="text-sm space-y-2">
          <li><a href="/rekrutacja" class="hover:text-primary-500 transition-colors">Rekrutacja</a></li>
          <li><a href="/dokumenty" class="hover:text-primary-500 transition-colors">Dokumenty i statuty</a></li>
          <li><a href="/rodo" class="hover:text-primary-500 transition-colors">RODO</a></li>
          <li><a href="/dostepnosc" class="hover:text-primary-500 transition-colors">Deklaracja dostępności</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-navy-800 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs">
      <p>&copy; {new Date().getFullYear()} Zespół Szkół Energetycznych i Usługowych w Łaziskach Górnych.</p>
      <button
        id="scroll-to-top"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded bg-primary-500 text-white hover:bg-primary-600 transition-colors cursor-pointer"
        aria-label="Powrót na górę strony">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 15l-6-6-6 6" />
        </svg>
        Powrót na górę
      </button>
    </div>
  </div>
</footer>

<script>
  document.getElementById('scroll-to-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
