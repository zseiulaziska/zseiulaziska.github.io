---
import '../styles/global.css';
import type { AstroComponentFactory } from 'astro';
import SkipLink from '../components/SkipLink.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<!doctype html>
<html lang="pl" class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Google Fonts for Inter (body) + Poppins (display) -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Skip link must be first focusable element -->
    <SkipLink />

    <header class="bg-gray-100 dark:bg-gray-900 text-gray-900 dark:text-gray-100">
      <Nav />
    </header>

    <main id="content" class="flex-1 max-w-6xl mx-auto px-4 py-8" tabindex="-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
