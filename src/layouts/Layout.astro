---
import '../styles/global.css';
import type { AstroComponentFactory } from 'astro';
import SkipLink from '../components/SkipLink.astro';
import MegaNav from '../components/MegaNav.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

interface Props {
  title?: string;
}

const { title = SITE_TITLE } = Astro.props;
---
<!doctype html>
<html lang="pl" class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a1628" media="(prefers-color-scheme: dark)" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
    <title>{title}</title>
    <meta name="description" content={title} />
    <slot name="head" />
    <script is:inline>
      (function() {
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)');
        if (prefersDark.matches) {
          document.documentElement.classList.add('dark');
        }
        prefersDark.addEventListener('change', function(e) {
          document.documentElement.classList.toggle('dark', e.matches);
        });
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <SkipLink />
    <MegaNav />
    <slot name="hero" />
    <main id="content" class="flex-1 max-w-6xl mx-auto px-4 py-8" tabindex="-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
