---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Technik Urządzeń i Systemów Energetyki Odnawialnej - ZSEiU Łaziska Górne" description="Technik urządzeń i systemów energetyki odnawialnej w ZSEiU Łaziska Górne – fotowoltaika, pompy ciepła, kolektory słoneczne, magazyny energii, OZE, uprawnienia SEP.">

  <article class="w-full max-w-5xl mx-auto min-w-0">

    <!-- HERO -->
    <div class="relative overflow-hidden rounded-2xl bg-linear-to-br from-slate-900 via-emerald-950 to-slate-900 dark:from-navy-950 dark:via-emerald-950/70 dark:to-navy-950 border border-slate-700/50 dark:border-emerald-900/30 p-5 sm:p-10 mb-10 w-full">
      <div class="cyber-grid absolute inset-0 opacity-20" aria-hidden="true"></div>
      <div class="cyber-glow absolute -top-20 -right-20 w-80 h-80 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="cyber-glow absolute -bottom-20 -left-20 w-80 h-80 bg-green-500/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="relative z-10">
        <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-emerald-500/20 text-emerald-300 border border-emerald-500/30 mb-4">Technikum w ZSEiU</span>
        <h1 class="text-3xl sm:text-5xl font-extrabold text-white mb-3 leading-tight wrap-break-word">Technik Urządzeń i Systemów <span class="text-transparent bg-clip-text bg-linear-to-r from-emerald-300 via-green-400 to-lime-400">Energetyki Odnawialnej</span></h1>
        <p class="text-base sm:text-xl text-slate-300 max-w-2xl leading-relaxed wrap-break-word">Zielona energia przyszłości – fotowoltaika, pompy ciepła, magazyny energii i inteligentne systemy OZE.</p>
      </div>
    </div>

    <!-- STATYSTYKI -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 sm:gap-4 my-10 w-full">
      <div class="stat-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-5 text-center min-w-0" data-count-to="5">
        <span class="block text-2xl sm:text-4xl font-extrabold text-emerald-600 dark:text-emerald-400"><span class="stat-value">0</span> lat</span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">nauki w technikum</span>
      </div>
      <div class="stat-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-5 text-center min-w-0" data-count-to="2">
        <span class="block text-2xl sm:text-4xl font-extrabold text-emerald-600 dark:text-emerald-400"><span class="stat-value">0</span></span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">kwalifikacje zawodowe</span>
      </div>
      <div class="stat-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-5 text-center min-w-0" data-count-to="70">
        <span class="block text-2xl sm:text-4xl font-extrabold text-emerald-600 dark:text-emerald-400"><span class="stat-value">0</span>+ lat</span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">tradycji szkoły</span>
      </div>
    </div>

    <!-- OBSZARY KSZTAŁCENIA -->
    <h2 class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white mt-10 mb-6 pl-3 sm:pl-4 border-l-4 border-emerald-500 leading-snug wrap-break-word">Obszary kształcenia</h2>

    <p class="text-base sm:text-lg leading-relaxed text-slate-700 dark:text-slate-300 mb-6 wrap-break-word">
      Kształcimy specjalistów w zakresie projektowania, montażu i eksploatacji systemów odnawialnych źródeł energii, przygotowując do pracy w dynamicznie rozwijającej się branży OZE.
    </p>

    <div class="grid grid-cols-2 xs:grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-3 mb-8 w-full">
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-emerald-400 dark:hover:border-emerald-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><circle cx="12" cy="12" r="5"></circle><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Fotowoltaika</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-emerald-400 dark:hover:border-emerald-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10zM2 12h20"></path></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Pompy ciepła</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-emerald-400 dark:hover:border-emerald-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><rect x="4" y="4" width="16" height="16" rx="2"></rect><path d="M8 12h8M12 8v8"></path></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Kolektory słoneczne</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-emerald-400 dark:hover:border-emerald-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Magazyny energii</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-emerald-400 dark:hover:border-emerald-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Uprawnienia SEP</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-emerald-400 dark:hover:border-emerald-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Inteligentne systemy</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-emerald-400 dark:hover:border-emerald-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Systemy CAD</span>
      </div>
    </div>

    <!-- CZEGO SIĘ NAUCZYSZ -->
    <h2 class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white mt-10 mb-6 pl-3 sm:pl-4 border-l-4 border-emerald-500 leading-snug wrap-break-word">Czego nauczysz się podczas nauki?</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8 w-full">
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-emerald-400 dark:hover:border-emerald-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center text-emerald-600 dark:text-emerald-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><circle cx="12" cy="12" r="5"></circle><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Systemy fotowoltaiczne</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>projektowanie i montaż instalacji PV</li>
              <li>dobór paneli fotowoltaicznych i falowników</li>
              <li>konfiguracja magazynów energii</li>
              <li>monitorowanie i optymalizacja wydajności</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-emerald-400 dark:hover:border-emerald-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center text-emerald-600 dark:text-emerald-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10zM2 12h20"></path></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Pompy ciepła i kolektory słoneczne</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>zasada działania pomp ciepła gruntowych i powietrznych</li>
              <li>montaż i uruchamianie instalacji solarnych</li>
              <li>dobór urządzeń do potrzeb budynku</li>
              <li>obsługa układów sterowania i regulacji</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-emerald-400 dark:hover:border-emerald-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center text-emerald-600 dark:text-emerald-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Magazyny energii i instalacje elektryczne</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>projektowanie systemów magazynowania energii</li>
              <li>budowa i konfiguracja instalacji elektrycznych OZE</li>
              <li>dobór zabezpieczeń i aparatury łączeniowej</li>
              <li>praca z systemami zarządzania energią (EMS)</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-emerald-400 dark:hover:border-emerald-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center text-emerald-600 dark:text-emerald-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Uprawnienia SEP i BHP</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>przygotowanie do egzaminu SEP do 1 kV</li>
              <li>bezpieczna eksploatacja urządzeń elektroenergetycznych</li>
              <li>ochrona przeciwporażeniowa i p-poż</li>
              <li>przepisy prawne w branży OZE</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-emerald-400 dark:hover:border-emerald-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center text-emerald-600 dark:text-emerald-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Projektowanie w CAD i kosztorysowanie</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>projektowanie instalacji OZE w programach CAD</li>
              <li>sporządzanie kosztorysów i ofert</li>
              <li>czytanie dokumentacji technicznej</li>
              <li>obliczenia wydajności i opłacalności inwestycji</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-emerald-400 dark:hover:border-emerald-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center text-emerald-600 dark:text-emerald-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Inteligentne systemy zarządzania energią</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>systemy Smart Home z integracją OZE</li>
              <li>monitoring zużycia i produkcji energii</li>
              <li>automatyka budynkowa i sterowanie</li>
              <li>optymalizacja autokonsumpcji</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- TIMELINE 5 LAT -->
    <h2 class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white mt-10 mb-6 pl-3 sm:pl-4 border-l-4 border-emerald-500 leading-snug wrap-break-word">Jak wygląda nauka w technikum?</h2>

    <p class="text-base sm:text-lg leading-relaxed text-slate-700 dark:text-slate-300 mb-6 wrap-break-word">
      Kształcenie trwa 5 lat i łączy przedmioty ogólne z zawodowymi. Przygotowujesz się do dwóch egzaminów potwierdzających kwalifikacje OZE.01 i OZE.02.
    </p>

    <div class="relative mb-8 w-full">
      <div class="hidden sm:block absolute left-1/2 top-0 bottom-0 w-0.5 bg-slate-200 dark:bg-navy-700 -translate-x-1/2"></div>
      <div class="space-y-6">
        <div class="relative flex flex-col sm:flex-row items-start gap-4 sm:gap-8">
          <div class="hidden sm:flex sm:w-1/2 justify-end">
            <div class="text-right">
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-slate-200 dark:bg-navy-700 text-slate-500 dark:text-slate-400 font-bold text-sm mb-1">I</span>
              <h3 class="font-bold text-slate-900 dark:text-white">Podstawy elektrotechniki i OZE</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400">Prawa prądu, BHP, podstawy fotowoltaiki</p>
            </div>
          </div>
          <div class="hidden sm:flex shrink-0 w-8 h-8 rounded-full bg-emerald-500 items-center justify-center ring-4 ring-white dark:ring-navy-900 z-10">
            <span class="text-white font-bold text-xs">1</span>
          </div>
          <div class="w-full sm:w-1/2">
            <div class="sm:hidden flex items-center gap-3 mb-1">
              <span class="shrink-0 w-6 h-6 rounded-full bg-emerald-500 flex items-center justify-center ring-2 ring-white dark:ring-navy-900"><span class="text-white font-bold text-xs">1</span></span>
              <h3 class="font-bold text-slate-900 dark:text-white min-w-0 flex-1 wrap-break-word">Klasa I – Podstawy elektrotechniki i OZE</h3>
            </div>
            <p class="text-sm text-slate-600 dark:text-slate-400 sm:hidden">Prawa prądu, BHP, podstawy fotowoltaiki</p>
            <p class="hidden sm:block text-sm text-slate-600 dark:text-slate-400 mt-1">Poznajesz podstawy elektrotechniki, BHP w branży OZE oraz zasady działania paneli fotowoltaicznych i kolektorów słonecznych.</p>
          </div>
        </div>

        <div class="relative flex flex-col sm:flex-row-reverse items-start gap-4 sm:gap-8">
          <div class="hidden sm:flex sm:w-1/2">
            <div>
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-slate-200 dark:bg-navy-700 text-slate-500 dark:text-slate-400 font-bold text-sm mb-1">II</span>
              <h3 class="font-bold text-slate-900 dark:text-white">Instalacje OZE i pomiary</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400">Montaż PV, pompy ciepła, pomiary instalacji</p>
            </div>
          </div>
          <div class="hidden sm:flex shrink-0 w-8 h-8 rounded-full bg-emerald-500 items-center justify-center ring-4 ring-white dark:ring-navy-900 z-10">
            <span class="text-white font-bold text-xs">2</span>
          </div>
          <div class="w-full sm:w-1/2 sm:text-right">
            <div class="sm:hidden flex items-center gap-3 mb-1">
