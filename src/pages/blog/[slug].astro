---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.filter(p => !p.data.draft).map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const posts = await getCollection('blog');
const post = posts.find(p => p.slug === slug && !p.data.draft);
if (!post) throw new Error(`Post not found: ${slug}`);
---

<Layout>
  <article class="prose max-w-4xl">
    <h1>{post.data.title}</h1>
    <div class="text-sm text-slate-600">{post.data.pubDate} — {post.data.author}</div>
    {post.body}
  </article>
</Layout>
