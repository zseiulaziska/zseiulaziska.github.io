---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const livePosts = posts.filter(p => !p.data.draft).sort((a,b) => b.data.pubDate.localeCompare(a.data.pubDate));
---

<Layout>
  <section class="prose max-w-4xl">
    <h1>Blog</h1>
    <p>Aktualności i wpisy związane ze szkołą.</p>

    <ul>
      {livePosts.map(post => (
        <li key={post.slug} class="py-2">
          <a href={`/blog/${post.slug}`} class="text-primary-700 hover:underline">{post.data.title}</a>
          <div class="text-sm text-slate-600">{post.data.pubDate} — {post.data.author}</div>
        </li>
      ))}
    </ul>
  </section>
</Layout>
