---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

let firstImageInBody = post.body?.match(/!\[.*?\]\((.+?)\)/)?.[1];
if (firstImageInBody && !firstImageInBody.startsWith('/') && !firstImageInBody.startsWith('http')) {
	firstImageInBody = '/images/blog/' + firstImageInBody;
}
const heroImage = post.data.heroImage || firstImageInBody;
---

<BlogPost {...post.data} heroImage={heroImage}>
	<Content />
</BlogPost>
