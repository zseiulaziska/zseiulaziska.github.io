---
import Layout from '../layouts/Layout.astro';
import SchoolFields from '../components/SchoolFields.astro';
---

<Layout title="Kierunki kształcenia - ZSEiU Łaziska Górne" description="Oferta edukacyjna ZSEiU Łaziska Górne. Sprawdź dostępne kierunki w technikum i szkole branżowej.">
  <article class="prose max-w-4xl dark:prose-invert">
    <h1>Kierunki kształcenia</h1>
    <p class="text-slate-600 dark:text-slate-300">Wybrane kierunki oferowane przez ZSEiU.</p>

    <SchoolFields variant="compact" />

    <p>Wiele kierunków ma partnerów branżowych zapewniających praktyki i wsparcie merytoryczne.</p>
  </article>
</Layout>
