---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Oddział Przygotowania Mundurowego – Technik Logistyk | ZSEiU Łaziska Górne" description="Oddział Przygotowania Mundurowego w ZSEiU Łaziska Górne – technik logistyk przygotowujący do służby w Policji i Straży Granicznej. Prawo, kryminalistyka, taktyka policyjna i profesjonalne kwalifikacje zawodowe.">

  <article class="w-full max-w-5xl mx-auto min-w-0">

    <!-- ═══ HERO ═══ -->
    <div class="relative overflow-hidden rounded-2xl mb-10 w-full">
      <!-- pełne, ciemne tło -->
      <div class="absolute inset-0" style="background: linear-gradient(135deg, #060d1a 0%, #091426 40%, #0a1a0e 100%);"></div>
      <!-- siatka -->
      <div class="opm-grid absolute inset-0 opacity-20" aria-hidden="true"></div>
      <!-- blask niebieski – lewa -->
      <div class="opm-glow-blue absolute -top-20 -left-10 w-80 h-80 rounded-full blur-3xl pointer-events-none" style="background: radial-gradient(circle, rgba(26,86,176,0.45) 0%, transparent 70%);" aria-hidden="true"></div>
      <!-- blask złoty – prawa -->
      <div class="opm-glow-gold absolute -bottom-20 -right-10 w-80 h-80 rounded-full blur-3xl pointer-events-none" style="background: radial-gradient(circle, rgba(201,162,39,0.35) 0%, transparent 70%);" aria-hidden="true"></div>
      <!-- dekoracyjna linia pionowa środek -->
      <div class="absolute inset-y-0 left-1/2 w-px -translate-x-1/2 hidden sm:block" style="background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.08) 30%, rgba(255,255,255,0.08) 70%, transparent);"></div>

      <div class="relative z-10 p-6 sm:p-10">
        <!-- badgy formacji -->
        <div class="flex flex-wrap gap-2 mb-6">
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold bg-[#1a56b0]/30 text-[#aaccff] border border-[#1a56b0]/50 tracking-wide uppercase">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-3.5 h-3.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
            Policja
          </span>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold bg-[#2d6627]/30 text-[#a0d890] border border-[#2d6627]/50 tracking-wide uppercase">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-3.5 h-3.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            Straż Graniczna
          </span>
        </div>

        <!-- nagłówek -->
        <h1 class="text-3xl sm:text-5xl font-extrabold text-white mb-4 leading-tight break-words drop-shadow-lg">
          Oddział<br>
          <span style="background: linear-gradient(90deg, #6eb0ff 0%, #4a8fd4 35%, #c9a227 65%, #f0d060 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Przygotowania Mundurowego</span>
        </h1>

        <!-- lead -->
        <p class="text-base sm:text-lg text-slate-200 max-w-2xl leading-relaxed break-words mb-6">
          Twoja droga do służby w <strong class="text-[#aaccff] font-bold">Policji</strong> i <strong class="text-[#f0d060] font-bold">Straży Granicznej</strong> – połącz mundurową pasję z zawodem <strong class="text-white">Technik Logistyk</strong>. Profesjonalne przygotowanie fizyczne, prawne i taktyczne już od pierwszej klasy.
        </p>

        <!-- dwie pieczęcie -->
        <div class="flex flex-wrap gap-3">
          <div class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl border" style="background: rgba(26,86,176,0.25); border-color: rgba(26,86,176,0.5);">
            <div class="w-8 h-8 rounded-full bg-[#1a56b0] flex items-center justify-center shrink-0 shadow-md shadow-[#1a56b0]/50">
              <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" class="w-4 h-4"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
            </div>
            <span class="text-sm font-bold text-white">Policja RP</span>
          </div>
          <div class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl border" style="background: rgba(45,102,39,0.25); border-color: rgba(45,102,39,0.5);">
            <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0 shadow-md shadow-[#2d6627]/40" style="background: linear-gradient(135deg,#2d6627,#4a8f3f);">
              <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" class="w-4 h-4"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <span class="text-sm font-bold text-white">Straż Graniczna</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ STATYSTYKI ═══ -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 my-10 w-full">
      <div class="stat-card rounded-xl bg-white dark:bg-[#0e1f3d]/60 border border-slate-200 dark:border-[#1a56b0]/30 p-3 sm:p-5 text-center min-w-0" data-count-to="5">
        <span class="block text-2xl sm:text-4xl font-extrabold text-[#1a56b0] dark:text-[#7eb3f5]"><span class="stat-value">0</span></span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">lat nauki w technikum</span>
      </div>
      <div class="stat-card rounded-xl bg-white dark:bg-[#162810]/60 border border-slate-200 dark:border-[#2d6627]/30 p-3 sm:p-5 text-center min-w-0" data-count-to="2">
        <span class="block text-2xl sm:text-4xl font-extrabold text-[#2d6627] dark:text-[#7ec87e]"><span class="stat-value">0</span></span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">kwalifikacje zawodowe</span>
      </div>
      <div class="stat-card rounded-xl bg-white dark:bg-[#0e1f3d]/60 border border-slate-200 dark:border-[#1a56b0]/30 p-3 sm:p-5 text-center min-w-0" data-count-to="70">
        <span class="block text-2xl sm:text-4xl font-extrabold text-[#1a56b0] dark:text-[#7eb3f5]"><span class="stat-value">0</span>+</span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">lat tradycji szkoły</span>
      </div>
      <div class="stat-card rounded-xl bg-white dark:bg-[#162810]/60 border border-slate-200 dark:border-[#2d6627]/30 p-3 sm:p-5 text-center min-w-0" data-count-to="2">
        <span class="block text-2xl sm:text-4xl font-extrabold text-[#2d6627] dark:text-[#7ec87e]"><span class="stat-value">0</span></span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">formacje mundurowe</span>
      </div>
    </div>

    <!-- ═══ CO TO JEST OPM ═══ -->
    <div class="rounded-2xl p-5 sm:p-7 mb-10 border overflow-hidden relative" style="background: linear-gradient(105deg, #eef4fd 0%, #f0f7ed 100%);">
      <div class="dark:hidden"></div>
      <div class="hidden dark:block absolute inset-0" style="background: linear-gradient(105deg, #0a1628cc 0%, #0f1e0acc 100%); border-radius: inherit;"></div>
      <div class="absolute inset-0 rounded-2xl border" style="border-image: linear-gradient(105deg, #1a56b0 0%, #2d6627 100%) 1;"></div>
      <div class="relative z-10 flex items-start gap-4">
        <div class="shrink-0 w-12 h-12 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, #1a56b0 0%, #2d6627 100%);">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" class="w-7 h-7"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
        </div>
        <div>
          <h2 class="text-lg sm:text-xl font-bold mb-2" style="background: linear-gradient(90deg, #1a56b0, #2d6627); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Czym jest Oddział Przygotowania Mundurowego?</h2>
          <p class="text-sm sm:text-base text-slate-700 dark:text-slate-300 leading-relaxed">
            Oddział Przygotowania Mundurowego (OPM) to klasa technikum łącząca pełnowartościowe wykształcenie zawodowe z wszechstronnym przygotowaniem do służby w formacjach mundurowych – <strong class="text-[#1a56b0] dark:text-[#7eb3f5]">Policji</strong> i <strong class="text-[#2d6627] dark:text-[#7ec87e]">Straży Granicznej</strong>. Uczniowie zdobywają zawód <strong>Technik Logistyk</strong> i jednocześnie kształtują sylwetkę odpowiedzialnego funkcjonariusza – sprawnego fizycznie, znającego prawo i procedury oraz gotowego do służby na rzecz bezpieczeństwa obywateli.
          </p>
        </div>
      </div>
    </div>

    <!-- ═══ FORMACJE – DWIE KARTY ═══ -->
    <h2 class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white mt-10 mb-6 pl-3 sm:pl-4 border-l-4 leading-snug break-words" style="border-color: #1a56b0;">Formacje mundurowe</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8 w-full">

      <!-- POLICJA – karta granatowa -->
      <div class="relative rounded-xl overflow-hidden border border-[#1a56b0]/40 hover:shadow-2xl hover:border-[#1a56b0]/70 transition-all duration-300 hover:-translate-y-0.5">
        <div class="absolute inset-0" style="background: linear-gradient(145deg, #0b1930 0%, #0f2248 55%, #091628 100%);"></div>
        <div class="absolute inset-0 opm-grid opacity-10"></div>
        <div class="absolute -top-10 -right-10 w-44 h-44 rounded-full blur-2xl" style="background: radial-gradient(circle, rgba(26,86,176,0.5) 0%, transparent 70%);"></div>
        <div class="relative z-10 p-6">
          <!-- nagłówek karty -->
          <div class="flex items-center gap-3 mb-4">
            <div class="shrink-0 w-14 h-14 rounded-xl bg-[#1a56b0] flex items-center justify-center shadow-xl shadow-[#1a56b0]/40">
              <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" class="w-8 h-8">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
            </div>
            <div>
              <h3 class="font-extrabold text-white text-xl leading-tight">Policja</h3>
              <span class="text-xs text-[#90bfff] font-semibold tracking-widest uppercase">Policja RP</span>
            </div>
          </div>
          <!-- pasek -->
          <div class="w-full h-1 rounded-full mb-4" style="background: linear-gradient(90deg, #1a56b0, #4a8fd4, #90bfff);"></div>
          <!-- opis -->
           <p class="text-sm text-white mb-4 leading-relaxed">
            Policja to formacja powołana do ochrony życia, zdrowia i mienia obywateli oraz wykrywania i ścigania sprawców przestępstw. Mundur granatowy z niebieską otoką – symbol ładu i bezpieczeństwa publicznego.
          </p>
          <!-- lista z punktorami -->
          <ul class="space-y-2.5">
            <li class="flex items-center gap-3 text-sm text-white font-medium">
              <span class="shrink-0 w-5 h-5 rounded-full bg-[#1a56b0] flex items-center justify-center">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" class="w-3 h-3"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              Policja Kryminalna
            </li>
            <li class="flex items-center gap-3 text-sm text-white font-medium">
              <span class="shrink-0 w-5 h-5 rounded-full bg-[#1a56b0] flex items-center justify-center">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" class="w-3 h-3"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              Policja Prewencyjna
            </li>
            <li class="flex items-center gap-3 text-sm text-white font-medium">
              <span class="shrink-0 w-5 h-5 rounded-full bg-[#1a56b0] flex items-center justify-center">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" class="w-3 h-3"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              Policja Drogowa
            </li>
            <li class="flex items-center gap-3 text-sm text-white font-medium">
              <span class="shrink-0 w-5 h-5 rounded-full bg-[#1a56b0] flex items-center justify-center">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" class="w-3 h-3"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              Służby logistyczne i administracyjne
            </li>
          </ul>
        </div>
      </div>

      <!-- STRAŻ GRANICZNA – karta zielona -->
      <div class="relative rounded-xl overflow-hidden border border-[#2d6627]/40 hover:shadow-2xl hover:border-[#c9a227]/40 transition-all duration-300 hover:-translate-y-0.5">
        <div class="absolute inset-0" style="background: linear-gradient(145deg, #0b1a07 0%, #122010 55%, #0a1508 100%);"></div>
        <div class="absolute inset-0 opm-grid opacity-10"></div>
        <div class="absolute -top-10 -right-10 w-44 h-44 rounded-full blur-2xl" style="background: radial-gradient(circle, rgba(201,162,39,0.35) 0%, transparent 70%);"></div>
        <div class="relative z-10 p-6">
          <!-- nagłówek karty -->
          <div class="flex items-center gap-3 mb-4">
            <div class="shrink-0 w-14 h-14 rounded-xl flex items-center justify-center shadow-xl shadow-[#2d6627]/40" style="background: linear-gradient(135deg, #2d6627, #4a8f3f);">
              <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" class="w-8 h-8">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </div>
            <div>
              <h3 class="font-extrabold text-white text-xl leading-tight">Straż Graniczna</h3>
              <span class="text-xs text-[#f0d060] font-semibold tracking-widest uppercase">Ochrona granicy RP</span>
            </div>
          </div>
          <!-- pasek -->
          <div class="w-full h-1 rounded-full mb-4" style="background: linear-gradient(90deg, #2d6627, #4a8f3f, #c9a227);"></div>
          <!-- opis -->
           <p class="text-sm text-white mb-4 leading-relaxed">
            Straż Graniczna to umundurowana i uzbrojona formacja chroniąca granicę RP i kontrolująca ruch graniczny. Mundur oliwkowy ze złotą dystynkcją – symbol ochrony suwerenności państwa.
          </p>
          <!-- lista z punktorami -->
          <ul class="space-y-2.5">
            <li class="flex items-center gap-3 text-sm text-white font-medium">
              <span class="shrink-0 w-5 h-5 rounded-full bg-[#c9a227] flex items-center justify-center">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" class="w-3 h-3"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              Oddziały graniczne
            </li>
            <li class="flex items-center gap-3 text-sm text-white font-medium">
              <span class="shrink-0 w-5 h-5 rounded-full bg-[#c9a227] flex items-center justify-center">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" class="w-3 h-3"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              Placówki Straży Granicznej
            </li>
            <li class="flex items-center gap-3 text-sm text-white font-medium">
              <span class="shrink-0 w-5 h-5 rounded-full bg-[#c9a227] flex items-center justify-center">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" class="w-3 h-3"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              Kontrola ruchu granicznego
            </li>
            <li class="flex items-center gap-3 text-sm text-white font-medium">
              <span class="shrink-0 w-5 h-5 rounded-full bg-[#c9a227] flex items-center justify-center">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" class="w-3 h-3"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              Jednostki logistyczne i transportowe
            </li>
          </ul>
        </div>
      </div>

    </div>

    <!-- ═══ PROGRAM PRZYGOTOWANIA ═══ -->
    <h2 class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white mt-10 mb-6 pl-3 sm:pl-4 border-l-4 leading-snug break-words" style="border-color: #1a56b0;">Program przygotowania mundurowego</h2>

    <p class="text-base sm:text-lg leading-relaxed text-slate-700 dark:text-slate-300 mb-6 break-words">
      Zajęcia mundurowe prowadzone są przez czynnych funkcjonariuszy Policji i Straży Granicznej oraz specjalistów bezpieczeństwa publicznego.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8 w-full">
      <!-- Prawo i procedury – niebieski -->
      <div class="skill-card rounded-xl bg-white dark:bg-[#0a1628]/70 border border-slate-200 dark:border-[#1a56b0]/25 p-4 sm:p-5 hover:shadow-lg hover:border-[#1a56b0]/60 dark:hover:border-[#1a56b0]/60 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-[#1a56b0]/10 dark:bg-[#1a56b0]/20 flex items-center justify-center text-[#1a56b0] dark:text-[#7eb3f5]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
          </span>
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2 mb-2">
              <h3 class="font-bold text-slate-900 dark:text-white break-words">Prawo i procedury</h3>
              <span class="text-[10px] px-1.5 py-0.5 rounded bg-[#1a56b0]/10 text-[#1a56b0] dark:bg-[#1a56b0]/20 dark:text-[#7eb3f5] font-semibold shrink-0">POLICJA</span>
            </div>
            <ul class="space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>podstawy prawa karnego i wykroczeniowego</li>
              <li>uprawnienia i obowiązki funkcjonariusza</li>
              <li>procedura karna i zatrzymanie osoby</li>
              <li>prawa człowieka w służbie mundurowej</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Kontrola graniczna – zielony -->
      <div class="skill-card rounded-xl bg-white dark:bg-[#0a1507]/70 border border-slate-200 dark:border-[#2d6627]/25 p-4 sm:p-5 hover:shadow-lg hover:border-[#2d6627]/60 dark:hover:border-[#c9a227]/40 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-[#2d6627]/10 dark:bg-[#2d6627]/20 flex items-center justify-center text-[#2d6627] dark:text-[#7ec87e]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
          </span>
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2 mb-2">
              <h3 class="font-bold text-slate-900 dark:text-white break-words">Kontrola graniczna</h3>
              <span class="text-[10px] px-1.5 py-0.5 rounded bg-[#2d6627]/10 text-[#2d6627] dark:bg-[#2d6627]/20 dark:text-[#7ec87e] font-semibold shrink-0">STR. GR.</span>
            </div>
            <ul class="space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>procedury odprawy granicznej osób i towarów</li>
              <li>dokumenty podróży i ich weryfikacja</li>
              <li>przepisy o ruchu granicznym i cudzoziemcach</li>
              <li>współpraca z Frontex i agencjami UE</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Szkolenie strzeleckie – niebieski -->
      <div class="skill-card rounded-xl bg-white dark:bg-[#0a1628]/70 border border-slate-200 dark:border-[#1a56b0]/25 p-4 sm:p-5 hover:shadow-lg hover:border-[#1a56b0]/60 dark:hover:border-[#1a56b0]/60 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-[#1a56b0]/10 dark:bg-[#1a56b0]/20 flex items-center justify-center text-[#1a56b0] dark:text-[#7eb3f5]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>
          </span>
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2 mb-2">
              <h3 class="font-bold text-slate-900 dark:text-white break-words">Szkolenie strzeleckie</h3>
              <span class="text-[10px] px-1.5 py-0.5 rounded font-semibold shrink-0 dark:text-[#7eb3f5]" style="background: linear-gradient(90deg,#1a56b010,#2d662710); color:#1a56b0;">OBU FORM.</span>
            </div>
            <ul class="space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>bezpieczne posługiwanie się bronią służbową</li>
              <li>budowa i konserwacja pistoletu</li>
              <li>zajęcia na strzelnicy i symulatorach</li>
              <li>taktyki strzeleckie Policji i SG</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Samoobrona – zielony -->
