---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Technik Stylista - ZSEiU Łaziska Górne" description="Technik stylista w ZSEiU Łaziska Górne – projektowanie mody, stylizacja, dobór materiałów, wizaż, marketing w branży fashion i obsługa klienta.">

  <article class="w-full max-w-5xl mx-auto min-w-0">

    <!-- HERO -->
    <div class="relative overflow-hidden rounded-2xl bg-linear-to-br from-slate-900 via-rose-950 to-slate-900 dark:from-navy-950 dark:via-rose-950/70 dark:to-navy-950 border border-slate-700/50 dark:border-rose-900/30 p-5 sm:p-10 mb-10 w-full">
      <div class="cyber-grid absolute inset-0 opacity-20" aria-hidden="true"></div>
      <div class="cyber-glow absolute -top-20 -right-20 w-80 h-80 bg-rose-500/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="cyber-glow absolute -bottom-20 -left-20 w-80 h-80 bg-pink-500/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="relative z-10">
        <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-rose-500/20 text-rose-300 border border-rose-500/30 mb-4">Technikum w ZSEiU</span>
        <h1 class="text-3xl sm:text-5xl font-extrabold text-white mb-3 leading-tight wrap-break-word">Technik <span class="text-transparent bg-clip-text bg-linear-to-r from-rose-300 via-pink-400 to-fuchsia-400">Stylista</span></h1>
        <p class="text-base sm:text-xl text-slate-300 max-w-2xl leading-relaxed wrap-break-word">Kreuj trendy i twórz styl – projektowanie mody, dobór materiałów, stylizacja, wizaż i marketing w branży fashion.</p>
      </div>
    </div>

    <!-- STATYSTYKI -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 sm:gap-4 my-10 w-full">
      <div class="stat-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-5 text-center min-w-0" data-count-to="5">
        <span class="block text-2xl sm:text-4xl font-extrabold text-rose-600 dark:text-rose-400"><span class="stat-value">0</span> lat</span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">nauki w technikum</span>
      </div>
      <div class="stat-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-5 text-center min-w-0" data-count-to="2">
        <span class="block text-2xl sm:text-4xl font-extrabold text-rose-600 dark:text-rose-400"><span class="stat-value">0</span></span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">kwalifikacje zawodowe</span>
      </div>
      <div class="stat-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-5 text-center min-w-0" data-count-to="70">
        <span class="block text-2xl sm:text-4xl font-extrabold text-rose-600 dark:text-rose-400"><span class="stat-value">0</span>+ lat</span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">tradycji szkoły</span>
      </div>
    </div>

    <!-- OBSZARY KSZTAŁCENIA -->
    <h2 class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white mt-10 mb-6 pl-3 sm:pl-4 border-l-4 border-rose-500 leading-snug wrap-break-word">Obszary kształcenia</h2>

    <p class="text-base sm:text-lg leading-relaxed text-slate-700 dark:text-slate-300 mb-6 wrap-break-word">
      Kształcimy specjalistów w zakresie projektowania i wykonywania odzieży, stylizacji, doboru materiałów oraz marketingu w branży fashion.
    </p>

    <div class="grid grid-cols-2 xs:grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-3 mb-8 w-full">
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-rose-400 dark:hover:border-rose-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M6 5v14M18 5v14M6 12h12M6 5L18 19M6 19L18 5"></path></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Projektowanie mody</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-rose-400 dark:hover:border-rose-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M20 7l-8 4-8-4"></path><path d="M12 21V11"></path><path d="M4 7v10l8 4 8-4V7"></path></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Dobór materiałów</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-rose-400 dark:hover:border-rose-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Stylizacja</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-rose-400 dark:hover:border-rose-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><path d="M12 17h.01"></path></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Wizaż</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-rose-400 dark:hover:border-rose-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><circle cx="12" cy="12" r="10"></circle><polyline points="2 12 7 12 9 16 13 8 15 12 22 12"></polyline></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Marketing</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-rose-400 dark:hover:border-rose-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Obsługa klienta</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-rose-400 dark:hover:border-rose-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><rect x="2" y="3" width="20" height="14" rx="2"></rect><path d="M8 21h8M12 17v4"></path></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Krawiectwo | CAD</span>
      </div>
    </div>

    <!-- CZEGO SIĘ NAUCZYSZ -->
    <h2 class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white mt-10 mb-6 pl-3 sm:pl-4 border-l-4 border-rose-500 leading-snug wrap-break-word">Czego nauczysz się podczas nauki?</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8 w-full">
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-rose-400 dark:hover:border-rose-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-rose-100 dark:bg-rose-900/40 flex items-center justify-center text-rose-600 dark:text-rose-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M6 5v14M18 5v14M6 12h12M6 5L18 19M6 19L18 5"></path></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Projektowanie odzieży</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>tworzenie rysunków projektowych i kolekcji odzieży</li>
              <li>modelowanie i konstrukcja wykrojów</li>
              <li>projektowanie z użyciem programów CAD</li>
              <li>określanie trendów w modzie</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-rose-400 dark:hover:border-rose-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-rose-100 dark:bg-rose-900/40 flex items-center justify-center text-rose-600 dark:text-rose-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M20 7l-8 4-8-4"></path><path d="M12 21V11"></path><path d="M4 7v10l8 4 8-4V7"></path></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Dobór materiałów i surowców</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>rozróżnianie rodzajów tkanin, dzianin i dodatków</li>
              <li>dobór materiałów do projektu i funkcji odzieży</li>
              <li>badanie właściwości i jakości materiałów</li>
              <li>ekologiczne i zrównoważone materiały</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-rose-400 dark:hover:border-rose-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-rose-100 dark:bg-rose-900/40 flex items-center justify-center text-rose-600 dark:text-rose-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Stylizacja i doradztwo</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>analiza typów sylwetki i kolorystyki</li>
              <li>komponowanie strojów i dodatków</li>
              <li>doradztwo w doborze garderoby</li>
              <li>kreowanie wizerunku i personal branding</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-rose-400 dark:hover:border-rose-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-rose-100 dark:bg-rose-900/40 flex items-center justify-center text-rose-600 dark:text-rose-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><path d="M12 17h.01"></path></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Wizaż i stylizacja fryzur</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>techniki makijażu dziennego i wieczorowego</li>
              <li>dobór makijażu do typu urody i okazji</li>
              <li>podstawy stylizacji fryzur</li>
              <li>charakteryzacja i makijaż artystyczny</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-rose-400 dark:hover:border-rose-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-rose-100 dark:bg-rose-900/40 flex items-center justify-center text-rose-600 dark:text-rose-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><circle cx="12" cy="12" r="10"></circle><polyline points="2 12 7 12 9 16 13 8 15 12 22 12"></polyline></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Marketing w branży fashion</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>promocja marki modowej i produktów</li>
              <li>social media i influencer marketing</li>
              <li>organizacja pokazów mody</li>
              <li>sprzedaż i obsługa klienta w salonie</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-rose-400 dark:hover:border-rose-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-rose-100 dark:bg-rose-900/40 flex items-center justify-center text-rose-600 dark:text-rose-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect x="2" y="3" width="20" height="14" rx="2"></rect><path d="M8 21h8M12 17v4"></path></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Konstrukcja i modelowanie odzieży</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>sporządzanie wykrojów podstawowych i modyfikowanych</li>
              <li>modelowanie techniką przestrzennego układania</li>
              <li>obsługa programów CAD do konstrukcji odzieży</li>
              <li>gradacja i układanie wykrojów na tkaninie</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- TIMELINE 5 LAT -->
    <h2 class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white mt-10 mb-6 pl-3 sm:pl-4 border-l-4 border-rose-500 leading-snug wrap-break-word">Jak wygląda nauka w technikum?</h2>

    <p class="text-base sm:text-lg leading-relaxed text-slate-700 dark:text-slate-300 mb-6 wrap-break-word">
      Nauka trwa 5 lat i łączy przedmioty ogólne z zawodowymi. Przygotowujesz się do dwóch egzaminów potwierdzających kwalifikacje MOD.03 i MOD.04.
    </p>

    <div class="relative mb-8 w-full">
      <div class="hidden sm:block absolute left-1/2 top-0 bottom-0 w-0.5 bg-slate-200 dark:bg-navy-700 -translate-x-1/2"></div>
      <div class="space-y-6">
        <div class="relative flex flex-col sm:flex-row items-start gap-4 sm:gap-8">
          <div class="hidden sm:flex sm:w-1/2 justify-end">
            <div class="text-right">
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-slate-200 dark:bg-navy-700 text-slate-500 dark:text-slate-400 font-bold text-sm mb-1">I</span>
              <h3 class="font-bold text-slate-900 dark:text-white">Podstawy projektowania i materiały</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400">Materiałoznawstwo, rysunek, BHP w branży</p>
            </div>
          </div>
          <div class="hidden sm:flex shrink-0 w-8 h-8 rounded-full bg-rose-500 items-center justify-center ring-4 ring-white dark:ring-navy-900 z-10">
            <span class="text-white font-bold text-xs">1</span>
          </div>
          <div class="w-full sm:w-1/2">
            <div class="sm:hidden flex items-center gap-3 mb-1">
              <span class="shrink-0 w-6 h-6 rounded-full bg-rose-500 flex items-center justify-center ring-2 ring-white dark:ring-navy-900"><span class="text-white font-bold text-xs">1</span></span>
              <h3 class="font-bold text-slate-900 dark:text-white min-w-0 flex-1 wrap-break-word">Klasa I – Podstawy projektowania i materiały</h3>
            </div>
            <p class="text-sm text-slate-600 dark:text-slate-400 sm:hidden">Materiałoznawstwo, rysunek, BHP w branży</p>
            <p class="hidden sm:block text-sm text-slate-600 dark:text-slate-400 mt-1">Poznajesz rodzaje materiałów, zasady BHP w branży mody oraz podstawy rysunku projektowego i kolorystyki.</p>
          </div>
        </div>

        <div class="relative flex flex-col sm:flex-row-reverse items-start gap-4 sm:gap-8">
          <div class="hidden sm:flex sm:w-1/2">
            <div>
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-slate-200 dark:bg-navy-700 text-slate-500 dark:text-slate-400 font-bold text-sm mb-1">II</span>
              <h3 class="font-bold text-slate-900 dark:text-white">Konstrukcja odzieży i wykroje</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400">Tworzenie wykrojów, modelowanie, szycie</p>
            </div>
          </div>
          <div class="hidden sm:flex shrink-0 w-8 h-8 rounded-full bg-rose-500 items-center justify-center ring-4 ring-white dark:ring-navy-900 z-10">
            <span class="text-white font-bold text-xs">2</span>
          </div>
          <div class="w-full sm:w-1/2 sm:text-right">
            <div class="sm:hidden flex items-center gap-3 mb-1">
              <span class="shrink-0 w-6 h-6 rounded-full bg-rose-500 flex items-center justify-center ring-2 ring-white dark:ring-navy-900"><span class="text-white font-bold text-xs">2</span></span>
              <h3 class="font-bold text-slate-900 dark:text-white min-w-0 flex-1 wrap-break-word">Klasa II – Konstrukcja odzieży i wykroje</h3>
            </div>
            <p class="text-sm text-slate-600 dark:text-slate-400 sm:hidden">Tworzenie wykrojów, modelowanie, szycie</p>
            <p class="hidden sm:block text-sm text-slate-600 dark:text-slate-400 mt-1">Uczysz się konstrukcji wykrojów i modelowania odzieży. Poznajesz techniki szycia i obsługę maszyn szwalniczych.</p>
          </div>
        </div>

        <div class="relative flex flex-col sm:flex-row items-start gap-4 sm:gap-8">
          <div class="hidden sm:flex sm:w-1/2 justify-end">
            <div class="text-right">
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-slate-200 dark:bg-navy-700 text-slate-500 dark:text-slate-400 font-bold text-sm mb-1">III</span>
              <h3 class="font-bold text-slate-900 dark:text-white">MOD.03 – egzamin i projektowanie kolekcji</h3>
