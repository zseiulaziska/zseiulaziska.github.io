---
import Layout from '../layouts/Layout.astro';
import staff from '../content/teacher/staff.json';

interface Teacher {
  name: string;
  subjects: string[];
}

const { management, teachers } = staff;

const lastName = (name: string) => name.split(' ').pop() ?? name;
const sorted: Teacher[] = [...teachers].sort((a, b) => lastName(a.name).localeCompare(lastName(b.name), "pl"));
const total = management.length + sorted.length;

const colors = [
  'from-primary-400 to-primary-600',
  'from-emerald-400 to-emerald-600',
  'from-violet-400 to-violet-600',
  'from-amber-400 to-amber-600',
  'from-rose-400 to-rose-600',
  'from-cyan-400 to-cyan-600',
  'from-fuchsia-400 to-fuchsia-600',
  'from-lime-400 to-lime-600',
  'from-orange-400 to-orange-600',
  'from-teal-400 to-teal-600',
];
function avatarColor(name: string): string {
  let hash = 0;
  for (let i = 0; i < name.length; i++) hash = name.charCodeAt(i) + ((hash << 5) - hash);
  return colors[Math.abs(hash) % colors.length];
}
function initials(name: string): string {
  const parts = name.split(' ');
  return parts.length >= 2 ? parts[0][0] + parts[parts.length - 1][0] : name[0];
}
---

<Layout>

  <article>
    <!-- Hero -->
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-slate-900 via-slate-800 to-primary-700 text-white mb-16 shadow-[inset_-2px_-2px_12px_rgba(0,0,0,0.2),8px_8px_24px_rgba(0,0,0,0.15)]">
      <div class="absolute inset-0 bg-slate-950/30"></div>
      <div class="absolute inset-0 opacity-[0.08]" style="background-image: radial-gradient(circle at 25% 25%, white 0%, transparent 50%), radial-gradient(circle at 75% 75%, white 0%, transparent 50%);"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 40px, white 40px, white 41px);"></div>
      <div class="relative px-8 py-16 lg:px-20 lg:py-24 text-center">
        <p class="text-primary-200 uppercase tracking-[0.2em] text-sm font-semibold">Rok szkolny 2025/2026</p>
        <h1 class="text-4xl lg:text-5xl font-bold mt-4" >Grono Pedagogiczne</h1>
        <p class="mt-3 text-lg text-white/80 max-w-xl mx-auto leading-relaxed">
          {total} nauczycieli i pracowników tworzących społeczność ZSEiU
        </p>
        <div class="mt-10 flex flex-wrap gap-3 justify-center">
          <a href="#dyrekcja" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/15 text-white rounded-xl font-semibold border border-white/20 hover:bg-white/25 transition-all duration-300 backdrop-blur-sm">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2"/></svg>
            Dyrekcja
          </a>
          <a href="#nauczyciele" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/15 text-white rounded-xl font-semibold border border-white/20 hover:bg-white/25 transition-all duration-300 backdrop-blur-sm">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 12v5c3 3 9 3 12 0v-5" stroke="currentColor" stroke-width="2"/></svg>
            Nauczyciele
          </a>
        </div>
      </div>
    </div>

    <!-- Dyrekcja -->
    <section id="dyrekcja" class="mb-20">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-8 text-center" >
        Dyrekcja i kierownictwo
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {
          management.map((person: any) => (
            <div class="p-6 rounded-2xl bg-white dark:bg-navy-800/90 border-2 border-primary-100 dark:border-primary-700/40 shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.03),4px_4px_12px_rgba(0,0,0,0.06)] hover:shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.03),6px_6px_20px_rgba(0,0,0,0.1)] transition-all duration-300 text-center">
              <div class="w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-primary-100 to-primary-200 dark:from-navy-700 dark:to-navy-600 flex items-center justify-center mb-4 shadow-md">
                <span class="text-2xl font-bold text-primary-700 dark:text-primary-300" >
                  {person.name.charAt(0)}
                </span>
              </div>
              <p class="font-bold text-lg text-slate-900 dark:text-white">{person.name}</p>
              <span class="inline-block mt-1.5 px-3 py-0.5 rounded-full bg-primary-100 text-primary-700 dark:bg-primary-700/30 dark:text-primary-300 text-xs font-semibold tracking-wide uppercase">
                {person.role}
              </span>
              <ul class="mt-4 space-y-1">
                {person.subjects.map((s: string) => (
                  <li class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{s}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Nauczyciele -->
    <section id="nauczyciele">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-8 text-center" >
        Nauczyciele
      </h2>

      <!-- Filter -->
      <div class="max-w-md mx-auto mb-8">
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/><path d="m21 21-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <label for="teacher-search" class="sr-only">Szukaj nauczyciela lub przedmiotu</label>
          <input
            type="search"
            id="teacher-search"
            placeholder="Szukaj nauczyciela lub przedmiotu..."
            class="w-full pl-10 pr-4 py-3 rounded-xl border border-slate-200 dark:border-navy-600 bg-white dark:bg-navy-800/90 text-slate-900 dark:text-white placeholder-slate-400 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-shadow"
          />
        </div>
      </div>

      <div id="teacher-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-6xl mx-auto">
        {
          sorted.map((person: Teacher) => (
            <div class="teacher-card p-5 rounded-2xl bg-white dark:bg-navy-800/90 border-2 border-slate-100 dark:border-navy-600 shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_12px_rgba(0,0,0,0.05)] hover:shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),6px_6px_20px_rgba(0,0,0,0.08)] hover:border-primary-200 dark:hover:border-primary-700 transition-all duration-300">
              <div class="flex items-center gap-3 mb-3">
                <div class={`w-10 h-10 rounded-full bg-gradient-to-br ${avatarColor(person.name)} flex items-center justify-center shadow-sm flex-shrink-0`}>
                  <span class="text-sm font-bold text-white">{initials(person.name)}</span>
                </div>
                <p class="font-semibold text-slate-900 dark:text-white">{person.name}</p>
              </div>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {person.subjects.map((s: string) => (
                  <span class="inline-block px-2.5 py-0.5 rounded-lg bg-slate-50 dark:bg-navy-700/60 text-xs text-slate-600 dark:text-slate-400 border border-slate-200 dark:border-navy-500 leading-relaxed">
                    {s}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
      <p id="no-results" class="hidden text-center text-slate-500 dark:text-slate-400 mt-8">Brak wyników</p>
    </section>

    <!-- Footer note -->
    <p class="max-w-3xl mx-auto mt-16 text-center text-sm text-slate-400 dark:text-slate-500">
      Stan na rok szkolny 2025/2026
    </p>
  </article>
</Layout>

<script>
  const search = document.getElementById('teacher-search') as HTMLInputElement | null;
  const grid = document.getElementById('teacher-grid');
  const noResults = document.getElementById('no-results');

  if (search && grid && noResults) {
    const cards = grid.querySelectorAll<HTMLDivElement>('.teacher-card');

    search.addEventListener('input', () => {
      const q = search.value.toLowerCase().trim();
      let count = 0;

      for (const card of cards) {
        const text = card.textContent?.toLowerCase() || '';
        const match = !q || text.includes(q);
        card.style.display = match ? '' : 'none';
        if (match) count++;
      }

      noResults.classList.toggle('hidden', count > 0);
    });
  }
</script>
