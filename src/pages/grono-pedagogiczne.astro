---

<Layout>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link slot="head" href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@500;600;700;800&display=swap" rel="stylesheet" />

  <article>
    <!-- Hero -->
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-slate-900 via-slate-800 to-primary-700 text-white mb-16 shadow-[inset_-2px_-2px_12px_rgba(0,0,0,0.2),8px_8px_24px_rgba(0,0,0,0.15)]">
      <div class="absolute inset-0 bg-slate-950/30"></div>
      <div class="absolute inset-0 opacity-[0.08]" style="background-image: radial-gradient(circle at 25% 25%, white 0%, transparent 50%), radial-gradient(circle at 75% 75%, white 0%, transparent 50%);"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 40px, white 40px, white 41px);"></div>
      <div class="relative px-8 py-16 lg:px-20 lg:py-24 text-center">
        <p class="text-primary-200 uppercase tracking-[0.2em] text-sm font-semibold">Rok szkolny 2025/2026</p>
        <h1 class="text-4xl lg:text-5xl font-bold mt-4" style="font-family: 'EB Garamond', serif;">Grono Pedagogiczne</h1>
        <p class="mt-3 text-lg text-white/80 max-w-xl mx-auto leading-relaxed">
          {total} nauczycieli i pracowników tworzących społeczność ZSEiU
        </p>
        <div class="mt-10 flex flex-wrap gap-3 justify-center">
          <a href="#dyrekcja" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/15 text-white rounded-xl font-semibold border border-white/20 hover:bg-white/25 transition-all duration-300 backdrop-blur-sm">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2"/></svg>
            Dyrekcja
          </a>
          <a href="#nauczyciele" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/15 text-white rounded-xl font-semibold border border-white/20 hover:bg-white/25 transition-all duration-300 backdrop-blur-sm">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 12v5c3 3 9 3 12 0v-5" stroke="currentColor" stroke-width="2"/></svg>
            Nauczyciele
          </a>
        </div>
      </div>
    </div>

    <!-- Dyrekcja -->
    <section id="dyrekcja" class="mb-20">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-8 text-center" style="font-family: 'EB Garamond', serif;">
        Dyrekcja i kierownictwo
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {
          management.map((person) => (
            <div class="p-6 rounded-2xl bg-white dark:bg-slate-800/90 border-2 border-primary-100 dark:border-primary-700/40 shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.03),4px_4px_12px_rgba(0,0,0,0.06)] hover:shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.03),6px_6px_20px_rgba(0,0,0,0.1)] transition-all duration-300 text-center">
              <div class="w-16 h-16 mx-auto rounded-full bg-gradient-to-br from-primary-100 to-primary-200 dark:from-primary-800 dark:to-primary-700 flex items-center justify-center mb-4 shadow-md">
                <span class="text-2xl font-bold text-primary-700 dark:text-primary-300" style="font-family: 'EB Garamond', serif;">
                  {person.name.charAt(0)}
                </span>
              </div>
              <p class="font-bold text-lg text-slate-900 dark:text-white">{person.name}</p>
              <span class="inline-block mt-1.5 px-3 py-0.5 rounded-full bg-primary-100 text-primary-700 dark:bg-primary-700/30 dark:text-primary-300 text-xs font-semibold tracking-wide uppercase">
                {person.role}
              </span>
              <ul class="mt-4 space-y-1">
                {person.subjects.map((s) => (
                  <li class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{s}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Nauczyciele -->
    <section id="nauczyciele">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-8 text-center" style="font-family: 'EB Garamond', serif;">
        Nauczyciele
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-6xl mx-auto">
        {
          sorted.map((person) => (
            <div class="p-5 rounded-2xl bg-white dark:bg-slate-800/90 border-2 border-slate-100 dark:border-slate-700 shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_12px_rgba(0,0,0,0.05)] hover:shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),6px_6px_20px_rgba(0,0,0,0.08)] hover:border-primary-200 dark:hover:border-primary-700 transition-all duration-300">
              <p class="font-semibold text-slate-900 dark:text-white">{person.name}</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {person.subjects.map((s) => (
                  <span class="inline-block px-2.5 py-0.5 rounded-lg bg-slate-50 dark:bg-slate-700/60 text-xs text-slate-600 dark:text-slate-400 border border-slate-200 dark:border-slate-600 leading-relaxed">
                    {s}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Footer note -->
    <p class="max-w-3xl mx-auto mt-16 text-center text-sm text-slate-400 dark:text-slate-500">
      Stan na rok szkolny 2025/2026
    </p>
  </article>
</Layout>
