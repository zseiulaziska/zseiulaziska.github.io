---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import { getCollection } from 'astro:content';
import IconMission from '../components/icons/IconMission.astro';
import IconStats from '../components/icons/IconStats.astro';
import IconContact from '../components/icons/IconContact.astro';
import IconLab from '../components/icons/IconLab.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.filter(p => !p.data.draft).sort((a,b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());
const latest = sortedPosts[0];
const latestThree = sortedPosts.slice(0, 3);
---

<Layout>
  <div slot="hero">
    <section class="md:hidden bg-white dark:bg-navy-800 border-b border-gray-200 dark:border-navy-700">
      <div class="flex items-center justify-around px-4 py-3 max-w-md mx-auto">
        <a href="#" title="Plan lekcji" aria-label="Plan lekcji"
          class="flex flex-col items-center gap-1 text-[11px] font-medium text-gray-600 dark:text-slate-300 hover:text-primary-500 dark:hover:text-primary-300 transition-colors">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
            <rect x="9" y="3" width="6" height="4" rx="1"/>
            <path d="M9 14l2 2 4-4"/>
          </svg>
          <span>Plan lekcji</span>
        </a>
        <a href="/plan-lekcji" title="Plan LO dla Dorosłych" aria-label="Plan LO"
          class="flex flex-col items-center gap-1 text-[11px] font-medium text-gray-600 dark:text-slate-300 hover:text-primary-500 dark:hover:text-primary-300 transition-colors">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
          <span>Plan LO dla Dorosłych</span>
        </a>
        <a href="https://uonetplus.vulcan.net.pl/powiatmikolowski" target="_blank" rel="noopener noreferrer" title="Dziennik elektroniczny" aria-label="Dziennik elektroniczny"
          class="flex flex-col items-center gap-1 text-[11px] font-medium text-gray-600 dark:text-slate-300 hover:text-primary-500 dark:hover:text-primary-300 transition-colors">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
            <path d="M8 7h8M8 11h6"/>
          </svg>
          <span>Dziennik</span>
        </a>
      </div>
    </section>
    <Hero />
  </div>

    <section class="py-20 lg:py-28 bg-white dark:bg-navy-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-14 space-y-4">
          <h2 class="text-xs font-bold text-primary-600 uppercase tracking-widest">Wpisy z bloga</h2>
          <p class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white">Aktualności</p>
          <p class="text-lg text-slate-600 dark:text-slate-300">Bądź na bieżąco z wydarzeniami w szkole</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          {latestThree.length > 0 ? latestThree.map((post) => (
              <a href={`/blog/${post.id}`}
              class="group flex flex-col bg-slate-50 dark:bg-navy-800 border border-slate-200 dark:border-navy-600 rounded-2xl overflow-hidden hover:shadow-xl transition-shadow">
              {post.data.heroImage ? (
                <img src={post.data.heroImage} alt={post.data.imageAlt || ''} class="w-full h-48 object-cover" />
              ) : (
                <div class="w-full h-48 bg-gray-200 dark:bg-navy-700 flex items-center justify-center text-slate-400">
                  <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" /></svg>
                </div>
              )}
              <div class="p-6 flex-1 flex flex-col">
                <time class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                  {new Date(post.data.pubDate).toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <h3 class="mt-3 text-lg font-bold text-slate-900 dark:text-white group-hover:text-primary-500 dark:group-hover:text-primary-300 transition-colors">
                  {post.data.title}
                </h3>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-300 leading-relaxed flex-1">
                  {post.data.description}
                </p>
                    <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary-600 dark:text-primary-300">
                  Czytaj więcej
                  <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/><path d="M12 5l7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </a>
          )) : (
            <p class="col-span-3 text-center text-slate-500 dark:text-slate-400">Brak opublikowanych wpisów.</p>
          )}
        </div>

        <div class="text-center mt-12">
          <a href="/blog"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary-600 text-white font-semibold hover:bg-primary-700 transition">
            Zobacz wszystkie wpisy
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </section>


  <section id="mundurowe" class="py-20 lg:py-28 bg-slate-50 dark:bg-navy-950">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
                <h2 class="text-xs font-bold text-primary-600 uppercase tracking-widest">Elitarny Profil Technikum nr 1</h2>
                <p class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white">Technik Logistyk – Klasy mundurowe i&nbsp;Oddziały Przygotowania Wojskowego</p>
                <p class="text-lg text-slate-600 dark:text-slate-300">
                    Nasz autorski program łączy pełne kształcenie zawodowe technika logistyka z wszechstronnym przygotowaniem do pracy w formacjach mundurowych.
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                <div class="bg-white dark:bg-navy-800 border border-slate-200 dark:border-navy-600 p-8 rounded-2xl shadow-sm hover:shadow-xl transition flex flex-col justify-between cursor-pointer">
                    <div class="space-y-4">
                        <div class="w-12 h-12 rounded-xl bg-slate-900 dark:bg-navy-700 text-white flex items-center justify-center">
                            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 dark:text-white">Przygotowanie do służby</h3>
                        <p class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed">
                            Zajęcia z zakresu funkcjonowania Policji, Straży Granicznej oraz innych formacji bezpieczeństwa publicznego. Poznasz procedury, prawo i etykę zawodową od podszewki.
                        </p>
                    </div>
                </div>

                <div class="bg-white dark:bg-navy-800 border border-slate-200 dark:border-navy-600 p-8 rounded-2xl shadow-sm hover:shadow-xl transition flex flex-col justify-between cursor-pointer">
                    <div class="space-y-4">
                        <div class="w-12 h-12 rounded-xl bg-blue-600 text-white flex items-center justify-center">
                            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 dark:text-white">Taktyka i strzelectwo</h3>
                        <p class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed">
                            Obozy poligonowe, regularne ćwiczenia taktyczne, musztra oraz zaawansowane szkolenia na naszej nowoczesnej <strong>wirtualnej strzelnicy</strong> dostępnej w budynku szkoły.
                        </p>
                    </div>
                </div>

                <div class="bg-white dark:bg-navy-800 border border-slate-200 dark:border-navy-600 p-8 rounded-2xl shadow-sm hover:shadow-xl transition flex flex-col justify-between cursor-pointer">
                    <div class="space-y-4">
                        <div class="w-12 h-12 rounded-xl bg-red-600 text-white flex items-center justify-center">
                            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 dark:text-white">Potęga Logistyki</h3>
                        <p class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed">
                            Zarządzanie łańcuchem dostaw, logistyka wojskowa i kryzysowa. Zdobywasz pełnoprawny tytuł Technika Logistyka, niezwykle pożądany również na cywilnym rynku pracy.
                        </p>
                    </div>
                </div>
            </div>

            <div class="mt-12 bg-slate-900 dark:bg-navy-700 text-white rounded-3xl p-8 lg:p-12 flex flex-col md:flex-row items-center justify-between gap-8">
                <div class="space-y-2">
                    <h4 class="text-xl font-bold">Unikalna szansa w regionie</h4>
                    <p class="text-slate-400 text-sm max-w-2xl">
                        Jesteśmy jedyną placówką w powiecie mikołowskim oferującą tak bogaty program klas mundurowych. Współpracujemy z lokalnymi komendami i jednostkami, dając Ci realną przewagę na starcie rekrutacji do służb mundurowych.
                    </p>
                </div>
                <a href="/kontakt" class="shrink-0 px-5 py-3 rounded-xl bg-white text-slate-900 font-bold hover:bg-slate-100 transition text-sm cursor-pointer">
                    Zapytaj o program zajęć
                </a>
            </div>

        </div>
    </section>



  <section class="py-12 bg-gray-50 dark:bg-navy-950 border-b border-gray-100 dark:border-navy-800">
    <div class="container max-w-6xl text-center">
      <h2 class="text-3xl font-bold text-slate-900 dark:text-white">Zespół Szkół Energetycznych i&nbsp;Usługowych w Łaziskach Górnych</h2>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 max-w-2xl mx-auto">Szkoła z tradycjami, stawiająca na nowoczesność, praktyczne umiejętności i sukcesy zawodowe naszych uczniów.</p>
    </div>
  </section>

<!-- Struktura organizacyjna -->
    <section id="struktura" class="max-w-4xl mx-auto mb-16 scroll-mt-20 py-12" >
      <h2 class="text-2xl font-bold text-center text-slate-900 dark:text-white mb-8">Struktura organizacyjna</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="p-6 rounded-2xl bg-white dark:bg-navy-800/90 border-2 border-primary-100 dark:border-primary-700/40 text-center shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_12px_rgba(6,166,255,0.08)]">
          <div class="w-12 h-12 rounded-xl bg-primary-100 dark:bg-primary-800/40 flex items-center justify-center mx-auto">
            <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="mt-4 font-semibold text-slate-900 dark:text-white">Technikum Nr 1</h3>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">5 lat &middot; matura + zawód</p>
        </div>
        <div class="p-6 rounded-2xl bg-white dark:bg-navy-800/90 border-2 border-primary-100 dark:border-primary-700/40 text-center shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_12px_rgba(6,166,255,0.08)]">
          <div class="w-12 h-12 rounded-xl bg-primary-100 dark:bg-primary-800/40 flex items-center justify-center mx-auto">
            <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2"/></svg>
          </div>
          <h3 class="mt-4 font-semibold text-slate-900 dark:text-white">Branżowa Szkoła I stopnia</h3>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">3 lata &middot; praktyka zawodowa</p>
        </div>
        <div class="p-6 rounded-2xl bg-white dark:bg-navy-800/90 border-2 border-primary-100 dark:border-primary-700/40 text-center shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_12px_rgba(6,166,255,0.08)]">
          <div class="w-12 h-12 rounded-xl bg-primary-100 dark:bg-primary-800/40 flex items-center justify-center mx-auto">
            <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 12v5c3 3 9 3 12 0v-5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </div>
          <h3 class="mt-4 font-semibold text-slate-900 dark:text-white">Branżowa Szkoła II stopnia</h3>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">2 lata &middot; uzupełnienie wykształcenia</p>
        </div>
        <div class="p-6 rounded-2xl bg-white dark:bg-navy-800/90 border-2 border-primary-100 dark:border-primary-700/40 text-center shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_12px_rgba(6,166,255,0.08)]">
          <div class="w-12 h-12 rounded-xl bg-primary-100 dark:bg-primary-800/40 flex items-center justify-center mx-auto">
            <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 016.5 17H20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" stroke="currentColor" stroke-width="2"/><path d="M8 7h8M8 11h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </div>
          <h3 class="mt-4 font-semibold text-slate-900 dark:text-white">LO dla Dorosłych</h3>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">3 lata &middot; zaocznie, bezpłatnie</p>
        </div>
      </div>
    </section>



  <Features />

