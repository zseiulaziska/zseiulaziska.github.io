---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Technik Organizacji Turystyki - ZSEiU Łaziska Górne" description="Technik organizacji turystyki w ZSEiU Łaziska Górne – obsługa ruchu turystycznego, pilotowanie wycieczek, biura podróży, języki obce i geografia turystyczna.">

  <article class="w-full max-w-5xl mx-auto min-w-0">

    <!-- HERO -->
    <div class="relative overflow-hidden rounded-2xl bg-linear-to-br from-slate-900 via-teal-950 to-slate-900 dark:from-navy-950 dark:via-teal-950/70 dark:to-navy-950 border border-slate-700/50 dark:border-teal-900/30 p-5 sm:p-10 mb-10 w-full">
      <div class="cyber-grid absolute inset-0 opacity-20" aria-hidden="true"></div>
      <div class="cyber-glow absolute -top-20 -right-20 w-80 h-80 bg-teal-500/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="cyber-glow absolute -bottom-20 -left-20 w-80 h-80 bg-cyan-500/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="relative z-10">
        <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-teal-500/20 text-teal-300 border border-teal-500/30 mb-4">Technikum w ZSEiU</span>
        <h1 class="text-3xl sm:text-5xl font-extrabold text-white mb-3 leading-tight wrap-break-word">Technik Organizacji <span class="text-transparent bg-clip-text bg-linear-to-r from-teal-300 via-cyan-400 to-emerald-400">Turystyki</span></h1>
        <p class="text-base sm:text-xl text-slate-300 max-w-2xl leading-relaxed wrap-break-word">Odkrywaj świat i zarządzaj podróżami – obsługa ruchu turystycznego, pilotowanie wycieczek, geografia i języki obce.</p>
      </div>
    </div>

    <!-- STATYSTYKI -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 sm:gap-4 my-10 w-full">
      <div class="stat-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-5 text-center min-w-0" data-count-to="5">
        <span class="block text-2xl sm:text-4xl font-extrabold text-teal-600 dark:text-teal-400"><span class="stat-value">0</span> lat</span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">nauki w technikum</span>
      </div>
      <div class="stat-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-5 text-center min-w-0" data-count-to="2">
        <span class="block text-2xl sm:text-4xl font-extrabold text-teal-600 dark:text-teal-400"><span class="stat-value">0</span></span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">kwalifikacje zawodowe</span>
      </div>
      <div class="stat-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-5 text-center min-w-0" data-count-to="70">
        <span class="block text-2xl sm:text-4xl font-extrabold text-teal-600 dark:text-teal-400"><span class="stat-value">0</span>+ lat</span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">tradycji szkoły</span>
      </div>
    </div>

    <!-- TECHNOLOGIE I OBSZARY -->
    <h2 class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white mt-10 mb-6 pl-3 sm:pl-4 border-l-4 border-teal-500 leading-snug wrap-break-word">Obszary kształcenia</h2>

    <p class="text-base sm:text-lg leading-relaxed text-slate-700 dark:text-slate-300 mb-6 wrap-break-word">
      Kształcimy specjalistów w zakresie organizacji i obsługi ruchu turystycznego, pilotowania wycieczek, zarządzania biurami podróży i promocji regionów.
    </p>

    <div class="grid grid-cols-2 xs:grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-3 mb-8 w-full">
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-teal-400 dark:hover:border-teal-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><circle cx="12" cy="12" r="10"></circle><path d="M2 12h20"></path><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Geografia turystyczna</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-teal-400 dark:hover:border-teal-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Pilotowanie</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-teal-400 dark:hover:border-teal-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Biuro podróży</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-teal-400 dark:hover:border-teal-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Języki obce</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-teal-400 dark:hover:border-teal-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><circle cx="12" cy="12" r="10"></circle><polyline points="2 12 7 12 9 16 13 8 15 12 22 12"></polyline></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Marketing turystyczny</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-teal-400 dark:hover:border-teal-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M3 9h18"></path><path d="M9 21V9"></path></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Kadry turystyki</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-3 sm:p-4 text-center min-w-0 hover:border-teal-400 dark:hover:border-teal-600 hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-navy-700 flex items-center justify-center text-slate-700 dark:text-slate-300 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white wrap-break-word">Obsługa klienta</span>
      </div>
    </div>

    <!-- CZEGO SIĘ NAUCZYSZ -->
    <h2 class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white mt-10 mb-6 pl-3 sm:pl-4 border-l-4 border-teal-500 leading-snug wrap-break-word">Czego nauczysz się podczas nauki?</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8 w-full">
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-teal-400 dark:hover:border-teal-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-teal-100 dark:bg-teal-900/40 flex items-center justify-center text-teal-600 dark:text-teal-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><circle cx="12" cy="12" r="10"></circle><path d="M2 12h20"></path><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Geografia turystyczna i waloryzacja regionów</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>charakterystyka regionów turystycznych Polski i świata</li>
              <li>walory i atrakcje turystyczne</li>
              <li>zagospodarowanie turystyczne regionów</li>
              <li>tworzenie programów zwiedzania</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-teal-400 dark:hover:border-teal-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-teal-100 dark:bg-teal-900/40 flex items-center justify-center text-teal-600 dark:text-teal-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Pilotowanie i przewodnictwo</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>pilotowanie wycieczek krajowych i zagranicznych</li>
              <li>oprowadzanie po atrakcjach turystycznych</li>
              <li>zarządzanie grupą turystyczną</li>
              <li>przygotowanie dokumentacji wycieczki</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-teal-400 dark:hover:border-teal-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-teal-100 dark:bg-teal-900/40 flex items-center justify-center text-teal-600 dark:text-teal-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Organizacja i obsługa biur podróży</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>tworzenie ofert turystycznych i kalkulacja kosztów</li>
              <li>obsługa systemów rezerwacyjnych</li>
              <li>sprzedaż usług turystycznych</li>
              <li>obsługa klienta w biurze podróży</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-teal-400 dark:hover:border-teal-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-teal-100 dark:bg-teal-900/40 flex items-center justify-center text-teal-600 dark:text-teal-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Języki obce w turystyce</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>angielski zawodowy w turystyce</li>
              <li>drugi język obcy (niemiecki, hiszpański)</li>
              <li>terminologia turystyczna i hotelarska</li>
              <li>komunikacja z klientem zagranicznym</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-teal-400 dark:hover:border-teal-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-teal-100 dark:bg-teal-900/40 flex items-center justify-center text-teal-600 dark:text-teal-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><circle cx="12" cy="12" r="10"></circle><polyline points="2 12 7 12 9 16 13 8 15 12 22 12"></polyline></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Marketing i promocja turystyczna</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>narzędzia promocji turystycznej i reklamy</li>
              <li>prowadzenie profili w mediach społecznościowych</li>
              <li>tworzenie materiałów promocyjnych i folderów</li>
              <li>współpraca z mediami i influencerami</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-navy-800/70 border border-slate-200 dark:border-navy-700 p-4 sm:p-5 hover:shadow-md hover:border-teal-400 dark:hover:border-teal-600 transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-teal-100 dark:bg-teal-900/40 flex items-center justify-center text-teal-600 dark:text-teal-400" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><path d="M12 17h.01"></path></svg></span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white wrap-break-word">Podstawy hotelarstwa i gastronomii</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>rodzaje obiektów hotelarskich i ich klasyfikacja</li>
              <li>organizacja usług gastronomicznych dla grup</li>
              <li>współpraca z hotelami i restauracjami</li>
              <li>rezerwacje i obsługa imprez</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- TIMELINE 5 LAT -->
    <h2 class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white mt-10 mb-6 pl-3 sm:pl-4 border-l-4 border-teal-500 leading-snug wrap-break-word">Jak wygląda nauka w technikum?</h2>

    <p class="text-base sm:text-lg leading-relaxed text-slate-700 dark:text-slate-300 mb-6 wrap-break-word">
      Nauka w technikum trwa 5 lat i łączy przedmioty ogólne z zawodowymi. Uczniowie przygotowują się do dwóch egzaminów zawodowych, zdobywając praktyczne umiejętności i kompetencje językowe.
    </p>

    <div class="relative mb-8 w-full">
      <div class="hidden sm:block absolute left-1/2 top-0 bottom-0 w-0.5 bg-slate-200 dark:bg-navy-700 -translate-x-1/2"></div>
      <div class="space-y-6">
        <div class="relative flex flex-col sm:flex-row items-start gap-4 sm:gap-8">
          <div class="hidden sm:flex sm:w-1/2 justify-end">
            <div class="text-right">
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-slate-200 dark:bg-navy-700 text-slate-500 dark:text-slate-400 font-bold text-sm mb-1">I</span>
              <h3 class="font-bold text-slate-900 dark:text-white">Podstawy turystyki i geografia</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400">Geografia turystyczna Polski, infrastruktura turystyczna</p>
            </div>
          </div>
          <div class="hidden sm:flex shrink-0 w-8 h-8 rounded-full bg-teal-500 items-center justify-center ring-4 ring-white dark:ring-navy-900 z-10">
            <span class="text-white font-bold text-xs">1</span>
          </div>
          <div class="w-full sm:w-1/2">
            <div class="sm:hidden flex items-center gap-3 mb-1">
              <span class="shrink-0 w-6 h-6 rounded-full bg-teal-500 flex items-center justify-center ring-2 ring-white dark:ring-navy-900"><span class="text-white font-bold text-xs">1</span></span>
              <h3 class="font-bold text-slate-900 dark:text-white min-w-0 flex-1 wrap-break-word">Klasa I – Podstawy turystyki i geografia</h3>
            </div>
            <p class="text-sm text-slate-600 dark:text-slate-400 sm:hidden">Geografia turystyczna Polski, infrastruktura turystyczna</p>
            <p class="hidden sm:block text-sm text-slate-600 dark:text-slate-400 mt-1">Poznajesz podstawy geografii turystycznej Polski, rodzaje infrastruktury i zasady funkcjonowania rynku turystycznego.</p>
          </div>
        </div>

        <div class="relative flex flex-col sm:flex-row-reverse items-start gap-4 sm:gap-8">
          <div class="hidden sm:flex sm:w-1/2">
            <div>
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-slate-200 dark:bg-navy-700 text-slate-500 dark:text-slate-400 font-bold text-sm mb-1">II</span>
              <h3 class="font-bold text-slate-900 dark:text-white">Biuro podróży i organizacja wycieczek</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400">Kalkulacje, oferty, systemy rezerwacyjne</p>
            </div>
          </div>
          <div class="hidden sm:flex shrink-0 w-8 h-8 rounded-full bg-teal-500 items-center justify-center ring-4 ring-white dark:ring-navy-900 z-10">
            <span class="text-white font-bold text-xs">2</span>
          </div>
          <div class="w-full sm:w-1/2 sm:text-right">
            <div class="sm:hidden flex items-center gap-3 mb-1">
              <span class="shrink-0 w-6 h-6 rounded-full bg-teal-500 flex items-center justify-center ring-2 ring-white dark:ring-navy-900"><span class="text-white font-bold text-xs">2</span></span>
              <h3 class="font-bold text-slate-900 dark:text-white min-w-0 flex-1 wrap-break-word">Klasa II – Biuro podróży i organizacja wycieczek</h3>
