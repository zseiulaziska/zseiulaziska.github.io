---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Oddział Przygotowania Wojskowego – Technik Logistyk | ZSEiU Łaziska Górne" description="Oddział Przygotowania Wojskowego w ZSEiU Łaziska Górne – technik logistyk w służbach mundurowych. Szkolenie wojskowe, zarządzanie łańcuchem dostaw, wychowanie fizyczne i patriotyczne.">

  <article class="w-full max-w-5xl mx-auto min-w-0">

    <!-- HERO -->
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-[#1a2613] via-[#243318] to-[#1a2613] border border-[#4a5c2e]/50 p-5 sm:p-10 mb-10 w-full">
      <div class="mil-grid absolute inset-0 opacity-20" aria-hidden="true"></div>
      <div class="mil-glow absolute -top-20 -right-20 w-80 h-80 bg-[#8da04a]/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="mil-glow absolute -bottom-20 -left-20 w-80 h-80 bg-[#c8a535]/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="relative z-10">
        <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-[#8da04a]/20 text-[#c8d97a] border border-[#8da04a]/30 mb-4">Technikum w ZSEiU – Klasy mundurowe</span>
        <h1 class="text-3xl sm:text-5xl font-extrabold text-white mb-3 leading-tight break-words">Oddział <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#c8d97a] via-[#a8c040] to-[#c8a535]">Przygotowania Wojskowego</span></h1>
        <p class="text-base sm:text-xl text-slate-300 max-w-2xl leading-relaxed break-words">Połącz pasję do służby z zawodem przyszłości – <strong class="text-[#c8d97a]">Technik Logistyk</strong> w mundurowej klasie OPW. Wychowanie patriotyczne, szkolenie wojskowe i profesjonalne kwalifikacje zawodowe w jednym miejscu.</p>
      </div>
    </div>

    <!-- STATYSTYKI -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 my-10 w-full">
      <div class="stat-card rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-3 sm:p-5 text-center min-w-0" data-count-to="5">
        <span class="block text-2xl sm:text-4xl font-extrabold text-[#6b8c2a] dark:text-[#a8c040]"><span class="stat-value">0</span></span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">lat nauki w technikum</span>
      </div>
      <div class="stat-card rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-3 sm:p-5 text-center min-w-0" data-count-to="2">
        <span class="block text-2xl sm:text-4xl font-extrabold text-[#6b8c2a] dark:text-[#a8c040]"><span class="stat-value">0</span></span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">kwalifikacje zawodowe</span>
      </div>
      <div class="stat-card rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-3 sm:p-5 text-center min-w-0" data-count-to="70">
        <span class="block text-2xl sm:text-4xl font-extrabold text-[#6b8c2a] dark:text-[#a8c040]"><span class="stat-value">0</span>+</span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">lat tradycji szkoły</span>
      </div>
      <div class="stat-card rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-3 sm:p-5 text-center min-w-0" data-count-to="160">
        <span class="block text-2xl sm:text-4xl font-extrabold text-[#6b8c2a] dark:text-[#a8c040]"><span class="stat-value">0</span>h</span>
        <span class="block mt-1 text-xs sm:text-base text-slate-600 dark:text-slate-400 leading-snug">szkolenia wojskowego rocznie</span>
      </div>
    </div>

    <!-- CO TO JEST OPW -->
    <div class="rounded-2xl bg-gradient-to-r from-[#f0f4e8] to-[#e8f0d8] dark:from-[#1e2a14]/80 dark:to-[#243318]/80 border border-[#8da04a]/30 p-5 sm:p-7 mb-10">
      <div class="flex items-start gap-4">
        <div class="shrink-0 w-12 h-12 rounded-xl bg-[#8da04a]/20 flex items-center justify-center text-[#6b8c2a] dark:text-[#a8c040]">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div>
          <h2 class="text-lg sm:text-xl font-bold text-[#3d5a0f] dark:text-[#c8d97a] mb-2">Czym jest Oddział Przygotowania Wojskowego?</h2>
          <p class="text-sm sm:text-base text-slate-700 dark:text-slate-300 leading-relaxed">
            Oddział Przygotowania Wojskowego (OPW) to innowacyjna forma kształcenia w technikum, łącząca pełnowartościowe wykształcenie zawodowe z systematycznym przygotowaniem militarnym. Program realizowany jest we współpracy z <strong>Centrum Wsparcia i Szkolenia Wojsk</strong> zgodnie z rozporządzeniem Ministra Obrony Narodowej. Uczniowie zdobywają zawód <strong>Technik Logistyk</strong> i jednocześnie otrzymują wszechstronne przygotowanie do służby wojskowej – fizyczne, strzeleckie, taktyczne i pierwszej pomocy.
          </p>
        </div>
      </div>
    </div>

    <!-- PROGRAM SZKOLENIA WOJSKOWEGO -->
    <h2 class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white mt-10 mb-6 pl-3 sm:pl-4 border-l-4 border-[#8da04a] leading-snug break-words">Program szkolenia wojskowego</h2>

    <p class="text-base sm:text-lg leading-relaxed text-slate-700 dark:text-slate-300 mb-6 break-words">
      Szkolenie wojskowe prowadzone jest przez wykwalifikowanych instruktorów wojskowych i obejmuje wiele obszarów przygotowania do służby.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8 w-full">
      <div class="skill-card rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-4 sm:p-5 hover:shadow-md hover:border-[#8da04a]/60 dark:hover:border-[#8da04a] transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-[#8da04a]/15 dark:bg-[#8da04a]/20 flex items-center justify-center text-[#6b8c2a] dark:text-[#a8c040]" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white break-words">Musztra i regulaminy</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>musztra indywidualna i zespołowa</li>
              <li>ceremoniał wojskowy i etykieta</li>
              <li>regulaminy Sił Zbrojnych RP</li>
              <li>honorowanie symboli narodowych i wojskowych</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-4 sm:p-5 hover:shadow-md hover:border-[#8da04a]/60 dark:hover:border-[#8da04a] transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-[#8da04a]/15 dark:bg-[#8da04a]/20 flex items-center justify-center text-[#6b8c2a] dark:text-[#a8c040]" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>
          </span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white break-words">Szkolenie strzeleckie</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>budowa i obsługa broni krótkiej i długiej</li>
              <li>bezpieczeństwo podczas strzelań</li>
              <li>techniki strzeleckie i ćwiczenia na strzelnicy</li>
              <li>szkolenie na symulatorach strzeleckich</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-4 sm:p-5 hover:shadow-md hover:border-[#8da04a]/60 dark:hover:border-[#8da04a] transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-[#8da04a]/15 dark:bg-[#8da04a]/20 flex items-center justify-center text-[#6b8c2a] dark:text-[#a8c040]" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white break-words">Taktyka i terenoznawstwo</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>orientacja w terenie i czytanie map</li>
              <li>podstawy taktyki bojowej</li>
              <li>maskowanie i przegrupowanie</li>
              <li>zajęcia w terenie – ćwiczenia polowe</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-4 sm:p-5 hover:shadow-md hover:border-[#8da04a]/60 dark:hover:border-[#8da04a] transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-[#8da04a]/15 dark:bg-[#8da04a]/20 flex items-center justify-center text-[#6b8c2a] dark:text-[#a8c040]" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white break-words">Pierwsza pomoc przedmedyczna</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>resuscytacja krążeniowo-oddechowa (RKO)</li>
              <li>opatrywanie ran i tamowanie krwotoków</li>
              <li>udzielanie pomocy w warunkach polowych</li>
              <li>obsługa sprzętu ratowniczego</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-4 sm:p-5 hover:shadow-md hover:border-[#8da04a]/60 dark:hover:border-[#8da04a] transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-[#8da04a]/15 dark:bg-[#8da04a]/20 flex items-center justify-center text-[#6b8c2a] dark:text-[#a8c040]" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white break-words">Sprawność fizyczna</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>rozszerzony program wychowania fizycznego</li>
              <li>marsze, biegi terenowe i ćwiczenia siłowe</li>
              <li>sporty walki i samoobrona</li>
              <li>testy sprawności fizycznej żołnierza</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="skill-card rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-4 sm:p-5 hover:shadow-md hover:border-[#8da04a]/60 dark:hover:border-[#8da04a] transition-all duration-300 min-w-0">
        <div class="flex items-start gap-3">
          <span class="shrink-0 w-10 h-10 rounded-lg bg-[#8da04a]/15 dark:bg-[#8da04a]/20 flex items-center justify-center text-[#6b8c2a] dark:text-[#a8c040]" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </span>
          <div class="min-w-0 flex-1">
            <h3 class="font-bold text-slate-900 dark:text-white break-words">Logistyka wojskowa</h3>
            <ul class="mt-2 space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
              <li>zabezpieczenie logistyczne pododdziałów</li>
              <li>gospodarka materiałowa i sprzętowa</li>
              <li>planowanie zaopatrzenia i transportu</li>
              <li>wojskowe systemy informatyczne</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- TECHNIK LOGISTYK – KWALIFIKACJE -->
    <h2 class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white mt-10 mb-6 pl-3 sm:pl-4 border-l-4 border-[#8da04a] leading-snug break-words">Zawód: Technik Logistyk</h2>

    <p class="text-base sm:text-lg leading-relaxed text-slate-700 dark:text-slate-300 mb-6 break-words">
      Technik logistyk to specjalista zarządzający przepływem towarów, informacji i zasobów w przedsiębiorstwach i instytucjach – w tym w strukturach mundurowych. Absolwent nabywa dwie kwalifikacje zawodowe potwierdzane egzaminami państwowymi.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
      <div class="rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-5 hover:shadow-md transition-all duration-300">
        <div class="flex items-center gap-3 mb-3">
          <span class="inline-flex items-center justify-center w-auto px-2 h-10 rounded-full bg-[#8da04a]/15 dark:bg-[#8da04a]/20 text-[#6b8c2a] dark:text-[#a8c040] font-extrabold text-xs shrink-0">SPL.01</span>
          <h3 class="font-bold text-slate-900 dark:text-white min-w-0 break-words">Obsługa magazynów</h3>
        </div>
        <ul class="space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
          <li>przyjmowanie i wydawanie towarów</li>
          <li>prowadzenie dokumentacji magazynowej</li>
          <li>obsługa systemów WMS i kodów kreskowych</li>
          <li>organizacja przestrzeni magazynowej</li>
          <li>inwentaryzacja i kontrola stanów</li>
        </ul>
      </div>
      <div class="rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-5 hover:shadow-md transition-all duration-300">
        <div class="flex items-center gap-3 mb-3">
          <span class="inline-flex items-center justify-center w-auto px-2 h-10 rounded-full bg-[#c8a535]/15 dark:bg-[#c8a535]/20 text-[#9a7a1a] dark:text-[#e2c050] font-extrabold text-xs shrink-0">SPL.02</span>
          <h3 class="font-bold text-slate-900 dark:text-white min-w-0 break-words">Organizacja transportu</h3>
        </div>
        <ul class="space-y-1 text-sm text-slate-600 dark:text-slate-400 list-disc list-inside">
          <li>planowanie tras i harmonogramów dostaw</li>
          <li>dobór środków transportu</li>
          <li>obsługa dokumentacji transportowej i celnej</li>
          <li>zarządzanie flotą pojazdów</li>
          <li>monitorowanie i rozliczanie przewozów</li>
        </ul>
      </div>
    </div>

    <!-- CZEGO SIĘ NAUCZYSZ -->
    <h2 class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white mt-10 mb-6 pl-3 sm:pl-4 border-l-4 border-[#8da04a] leading-snug break-words">Czego nauczysz się podczas nauki?</h2>

    <div class="grid grid-cols-2 xs:grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-3 mb-8 w-full">
      <div class="tech-chip rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-3 sm:p-4 text-center min-w-0 hover:border-[#8da04a]/60 dark:hover:border-[#8da04a] hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-[#2a3a18] flex items-center justify-center text-[#6b8c2a] dark:text-[#a8c040] shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white break-words">Transport</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-3 sm:p-4 text-center min-w-0 hover:border-[#8da04a]/60 dark:hover:border-[#8da04a] hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-[#2a3a18] flex items-center justify-center text-[#6b8c2a] dark:text-[#a8c040] shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white break-words">Magazynowanie</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-3 sm:p-4 text-center min-w-0 hover:border-[#8da04a]/60 dark:hover:border-[#8da04a] hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-[#2a3a18] flex items-center justify-center text-[#6b8c2a] dark:text-[#a8c040] shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white break-words">Zaopatrzenie</span>
      </div>
      <div class="tech-chip rounded-xl bg-white dark:bg-[#1e2a14]/70 border border-slate-200 dark:border-[#4a5c2e] p-3 sm:p-4 text-center min-w-0 hover:border-[#8da04a]/60 dark:hover:border-[#8da04a] hover:shadow-md transition-all duration-300">
        <div class="w-10 h-10 mx-auto mb-2 rounded-lg bg-slate-100 dark:bg-[#2a3a18] flex items-center justify-center text-[#6b8c2a] dark:text-[#a8c040] shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <span class="block text-xs sm:text-sm font-semibold text-slate-900 dark:text-white break-words">Szkolenie wojsk.</span>
      </div>
