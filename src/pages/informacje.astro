---
import Layout from '../layouts/Layout.astro';
import InformacjeSection from '../components/InformacjeSection.astro';
---

<Layout>
  <InformacjeSection slot="hero" />

  <article>

    <!-- Navigation -->
    <nav aria-label="Spis treści" class="max-w-4xl mx-auto mb-12">
      <div class="flex flex-wrap gap-2 justify-center">
        <a href="#najwazniejsze" class="px-4 py-2 text-sm font-medium rounded-xl bg-white dark:bg-navy-800/60 border border-gray-200 dark:border-navy-700 text-slate-700 dark:text-slate-300 hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-700 dark:hover:text-primary-300 transition-all">Najważniejsze</a>
        <a href="#misja" class="px-4 py-2 text-sm font-medium rounded-xl bg-white dark:bg-navy-800/60 border border-gray-200 dark:border-navy-700 text-slate-700 dark:text-slate-300 hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-700 dark:hover:text-primary-300 transition-all">Misja</a>
        <a href="#struktura" class="px-4 py-2 text-sm font-medium rounded-xl bg-white dark:bg-navy-800/60 border border-gray-200 dark:border-navy-700 text-slate-700 dark:text-slate-300 hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-700 dark:hover:text-primary-300 transition-all">Struktura</a>
        <a href="#kierunki" class="px-4 py-2 text-sm font-medium rounded-xl bg-white dark:bg-navy-800/60 border border-gray-200 dark:border-navy-700 text-slate-700 dark:text-slate-300 hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-700 dark:hover:text-primary-300 transition-all">Kierunki</a>
        <a href="#infrastruktura" class="px-4 py-2 text-sm font-medium rounded-xl bg-white dark:bg-navy-800/60 border border-gray-200 dark:border-navy-700 text-slate-700 dark:text-slate-300 hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-700 dark:hover:text-primary-300 transition-all">Infrastruktura</a>
        <a href="#projekty" class="px-4 py-2 text-sm font-medium rounded-xl bg-white dark:bg-navy-800/60 border border-gray-200 dark:border-navy-700 text-slate-700 dark:text-slate-300 hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-700 dark:hover:text-primary-300 transition-all">Projekty</a>
        <a href="#kontakt" class="px-4 py-2 text-sm font-medium rounded-xl bg-white dark:bg-navy-800/60 border border-gray-200 dark:border-navy-700 text-slate-700 dark:text-slate-300 hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-700 dark:hover:text-primary-300 transition-all">Kontakt</a>
      </div>
    </nav>

    <!-- Najważniejsze informacje -->
    <section id="najwazniejsze" class="max-w-4xl mx-auto mb-16 scroll-mt-20">
      <div class="p-8 lg:p-10 rounded-3xl bg-primary-50 dark:bg-navy-800/60 border-2 border-primary-100 dark:border-primary-700/40 shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_16px_rgba(6,166,255,0.08)]">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white" >Najważniejsze informacje</h2>
        <dl class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4">
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">Nazwa</dt>
            <dd class="mt-1 text-slate-900 dark:text-white font-medium">Zespół Szkół Energetycznych i Usługowych (ZSEiU) w Łaziskach Górnych</dd>
          </div>
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">Adres</dt>
            <dd class="mt-1 text-slate-900 dark:text-white font-medium">ul. Chopina 11b, 43-170 Łaziska Górne</dd>
          </div>
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">Telefon</dt>
            <dd class="mt-1 text-slate-900 dark:text-white font-medium">32 224 24 15</dd>
          </div>
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">E-mail</dt>
            <dd class="mt-1"><a href="mailto:sekretariat@zseiulaziska.pl" class="text-primary-600 dark:text-primary-400 hover:underline font-medium">sekretariat@zseiulaziska.pl</a></dd>
          </div>
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">Dyrektor</dt>
            <dd class="mt-1 text-slate-900 dark:text-white font-medium">mgr Anna Jadasz</dd>
          </div>
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">Wicedyrektor</dt>
            <dd class="mt-1 text-slate-900 dark:text-white font-medium">mgr Dorota Brudny</dd>
          </div>
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">Kierownik szkolenia praktycznego</dt>
            <dd class="mt-1 text-slate-900 dark:text-white font-medium">mgr inż. Piotr Dębowski</dd>
          </div>
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">Statystyki (2025/2026)</dt>
            <dd class="mt-1 text-slate-900 dark:text-white font-medium">~520 uczniów, ~57 nauczycieli, 22 oddziały</dd>
          </div>
        </dl>
      </div>
    </section>

    

    <!-- Struktura organizacyjna -->
    <section id="struktura" class="max-w-4xl mx-auto mb-16 scroll-mt-20">
      <h2 class="text-2xl font-bold text-center text-slate-900 dark:text-white mb-8" >Struktura organizacyjna</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="p-6 rounded-2xl bg-white dark:bg-navy-800/90 border-2 border-primary-100 dark:border-primary-700/40 text-center shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_12px_rgba(6,166,255,0.08)]">
          <div class="w-12 h-12 rounded-xl bg-primary-100 dark:bg-primary-800/40 flex items-center justify-center mx-auto">
            <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3 class="mt-4 font-semibold text-slate-900 dark:text-white">Technikum Nr 1</h3>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">5 lat &middot; matura + zawód</p>
        </div>
        <div class="p-6 rounded-2xl bg-white dark:bg-navy-800/90 border-2 border-primary-100 dark:border-primary-700/40 text-center shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_12px_rgba(6,166,255,0.08)]">
          <div class="w-12 h-12 rounded-xl bg-primary-100 dark:bg-primary-800/40 flex items-center justify-center mx-auto">
            <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2"/></svg>
          </div>
          <h3 class="mt-4 font-semibold text-slate-900 dark:text-white">Branżowa Szkoła I stopnia</h3>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">3 lata &middot; praktyka zawodowa</p>
        </div>
        <div class="p-6 rounded-2xl bg-white dark:bg-navy-800/90 border-2 border-primary-100 dark:border-primary-700/40 text-center shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_12px_rgba(6,166,255,0.08)]">
          <div class="w-12 h-12 rounded-xl bg-primary-100 dark:bg-primary-800/40 flex items-center justify-center mx-auto">
            <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 12v5c3 3 9 3 12 0v-5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </div>
          <h3 class="mt-4 font-semibold text-slate-900 dark:text-white">Branżowa Szkoła II stopnia</h3>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">2 lata &middot; uzupełnienie wykształcenia</p>
        </div>
        <div class="p-6 rounded-2xl bg-white dark:bg-navy-800/90 border-2 border-primary-100 dark:border-primary-700/40 text-center shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_12px_rgba(6,166,255,0.08)]">
          <div class="w-12 h-12 rounded-xl bg-primary-100 dark:bg-primary-800/40 flex items-center justify-center mx-auto">
            <svg class="w-6 h-6 text-primary-600 dark:text-primary-400" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 016.5 17H20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" stroke="currentColor" stroke-width="2"/><path d="M8 7h8M8 11h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </div>
          <h3 class="mt-4 font-semibold text-slate-900 dark:text-white">LO dla Dorosłych</h3>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">3 lata &middot; zaocznie, bezpłatnie</p>
        </div>
      </div>
    </section>

    <!-- Kierunki kształcenia -->
    <section id="kierunki" class="max-w-4xl mx-auto mb-16 scroll-mt-20">
      <div class="p-8 lg:p-10 rounded-3xl bg-gradient-to-br from-primary-50 to-primary-100 dark:from-navy-800 dark:to-navy-800/60 border-2 border-primary-200 dark:border-primary-700/40 shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_16px_rgba(6,166,255,0.08)]">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white text-center" >Kierunki kształcenia</h2>
        <p class="mt-2 text-center text-slate-600 dark:text-slate-400">Oferta edukacyjna:</p>
        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <h3 class="font-semibold text-slate-900 dark:text-white flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-primary-500"></span>
              Technikum Nr 1
            </h3>
            <ul class="mt-3 space-y-2">
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Technik elektryk
              </li>
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Technik informatyk
              </li>
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Technik logistyk (w tym klasa policyjna / mundurowa)
              </li>
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Technik urządzeń i systemów energetyki odnawialnej (OZE)
              </li>
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Technik organizacji turystyki
              </li>
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Technik stylista
              </li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 dark:text-white flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-primary-500"></span>
              Branżowa Szkoła I stopnia
            </h3>
            <ul class="mt-3 space-y-2">
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Mechanik-monter maszyn i urządzeń
              </li>
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Operator maszyn i urządzeń do przetwórstwa tworzyw sztucznych
              </li>

              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                klasa wielozawodowa
              </li>
            </ul>
            <h3 class="mt-6 font-semibold text-slate-900 dark:text-white flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-primary-500"></span>
              Branżowa Szkoła II stopnia
            </h3>
            <ul class="mt-3 space-y-2">
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Technik mechanik
              </li>
            </ul>
            <h3 class="mt-6 font-semibold text-slate-900 dark:text-white flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-primary-500"></span>
              Liceum Ogólnokształcące dla Dorosłych
            </h3>
            <ul class="mt-3 space-y-2">
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Profil ogólny &mdash; nauka bezpłatna, zaoczna
              </li>
            </ul>
          </div>
        </div>
        <div class="mt-8 text-center">
          <a href="/kierunki" class="inline-flex items-center gap-2 px-6 py-3 bg-primary-600 text-white rounded-xl font-semibold hover:bg-primary-700 transition-all duration-300 shadow-md hover:shadow-lg focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary-500 focus-visible:ring-offset-2">
            Szczegółowe kierunki
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Klasy mundurowe -->
    <section id="klasy-mundurowe" class="max-w-4xl mx-auto mb-16 scroll-mt-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div class="p-8 rounded-3xl bg-white dark:bg-navy-800/90 border-2 border-slate-100 dark:border-navy-600 shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_12px_rgba(0,0,0,0.06)]">
          <h2 class="text-2xl font-bold text-slate-900 dark:text-white" >Klasy mundurowe</h2>
          <p class="mt-4 text-slate-600 dark:text-slate-300 leading-relaxed">
            ZSEiU prowadzi klasy mundurowe (m.in. klasa policyjna) &mdash; <strong class="text-slate-900 dark:text-white font-semibold">jedyna taka oferta w powiecie</strong>. Program łączy kształcenie zawodowe (technik logistyk) z dodatkowymi zajęciami taktycznymi, poligonami, strzelectwem i przygotowaniem do służb mundurowych.
          </p>
          <p class="mt-3 text-slate-600 dark:text-slate-300 leading-relaxed">
            Klasy funkcjonują pod patronatem Policji, co otwiera dodatkowe możliwości rozwoju zawodowego. Absolwenci otrzymują dodatkowe punkty przy rekrutacji do służby w Policji.
          </p>
          <a href="/klasy-mundurowe" class="mt-6 inline-flex items-center gap-2 text-primary-600 dark:text-primary-400 font-semibold hover:underline">
            Więcej o klasach mundurowych
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        <div class="p-8 rounded-3xl bg-white dark:bg-navy-800/90 border-2 border-slate-100 dark:border-navy-600 shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_12px_rgba(0,0,0,0.06)]">
          <h2 class="text-2xl font-bold text-slate-900 dark:text-white" >Współpraca z partnerami</h2>
          <p class="mt-4 text-slate-600 dark:text-slate-300 leading-relaxed">
            Szkoła współpracuje z wiodącymi firmami branżowymi:
          </p>
          <ul class="mt-4 space-y-3">
            <li class="flex items-start gap-3">
              <span class="mt-1 w-2 h-2 rounded-full bg-primary-500 flex-shrink-0"></span>
              <div>
                <strong class="text-slate-900 dark:text-white">TAURON SERWIS / TAURON WYTWARZANIE</strong>
                <p class="text-sm text-slate-600 dark:text-slate-400">Klasy patronackie i stypendia dla kierunku technik energetyk; doposażenie laboratoriów.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-2 h-2 rounded-full bg-primary-500 flex-shrink-0"></span>
              <div>
                <strong class="text-slate-900 dark:text-white">bekuplast S.A.</strong>
                <p class="text-sm text-slate-600 dark:text-slate-400">Współpraca w zakresie kierunku magazynier-logistyk, praktyki w warunkach rzeczywistych.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-2 h-2 rounded-full bg-primary-500 flex-shrink-0"></span>
              <div>
                <strong class="text-slate-900 dark:text-white">Polska Grupa Górnicza</strong>
                <p class="text-sm text-slate-600 dark:text-slate-400">Gwarancja zatrudnienia i stypendia dla uczniów kierunków górniczych.</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Infrastruktura i pracownie -->
    <section id="infrastruktura" class="max-w-4xl mx-auto mb-16 scroll-mt-20">
      <h2 class="text-2xl font-bold text-center text-slate-900 dark:text-white mb-8" >Infrastruktura i pracownie</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="p-5 rounded-xl bg-white dark:bg-navy-800/60 border border-gray-200 dark:border-navy-700 shadow-sm hover:shadow-md transition-all">
          <div class="w-10 h-10 rounded-lg bg-primary-100 dark:bg-primary-800/40 flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" stroke="currentColor" stroke-width="2"/></svg>
          </div>
          <h3 class="mt-3 font-semibold text-slate-900 dark:text-white text-sm">Laboratorium TAURON</h3>
          <p class="mt-1 text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Inteligentne domy i automatyka przemysłowa &mdash; doposażone w ramach konkursu TAURONA.</p>
        </div>
        <div class="p-5 rounded-xl bg-white dark:bg-navy-800/60 border border-gray-200 dark:border-navy-700 shadow-sm hover:shadow-md transition-all">
          <div class="w-10 h-10 rounded-lg bg-primary-100 dark:bg-primary-800/40 flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </div>
          <h3 class="mt-3 font-semibold text-slate-900 dark:text-white text-sm">Pracownia OZE</h3>
          <p class="mt-1 text-xs text-slate-500 dark:text-slate-400 leading-relaxed">Nowoczesne laboratorium energetyki odnawialnej z projektu &bdquo;Efektywne Funkcjonalne Szkoły&rdquo;.</p>
        </div>
        <div class="p-5 rounded-xl bg-white dark:bg-navy-800/60 border border-gray-200 dark:border-navy-700 shadow-sm hover:shadow-md transition-all">
          <div class="w-10 h-10 rounded-lg bg-primary-100 dark:bg-primary-800/40 flex items-center justify-center">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2" stroke="currentColor" stroke-width="2"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </div>
          <h3 class="mt-3 font-semibold text-slate-900 dark:text-white text-sm">Pracownie informatyczne</h3>
          <p class="mt-1 text-xs text-slate-500 dark:text-slate-400 leading-relaxed">W pełni wyposażone sale komputerowe, partner GitHub Campus Program.</p>
        </div>
        <div class="p-5 rounded-xl bg-white dark:bg-navy-800/60 border border-gray-200 dark:border-navy-700 shadow-sm hover:shadow-md transition-all">
