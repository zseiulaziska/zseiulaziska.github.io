---
import Layout from '../layouts/Layout.astro';
import InformacjeSection from '../components/InformacjeSection.astro';
import InfoStructure from '../components/InfoStructure.astro';
import InfoInfrastructure from '../components/InfoInfrastructure.astro';
import TableOfContents from '../components/TableOfContents.astro';

const tocSections = [
  { id: 'najwazniejsze', label: 'Najważniejsze' },
  { id: 'struktura', label: 'Struktura' },
  { id: 'kierunki', label: 'Kierunki' },
  { id: 'klasy-mundurowe', label: 'Klasy mundurowe' },
  { id: 'infrastruktura', label: 'Infrastruktura' },
  { id: 'projekty', label: 'Projekty' },
  { id: 'dokumenty', label: 'Dokumenty' },
  { id: 'kontakt', label: 'Kontakt' },
];
---

<Layout title="Informacje o szkole - ZSEiU Łaziska Górne" description="Poznaj Zespół Szkół Energetycznych i Usługowych w Łaziskach Górnych. Historia, misja, struktura i infrastruktura szkoły.">
  <InformacjeSection slot="hero" />

  <article>

    <!-- Navigation -->
    <nav aria-label="Spis treści" class="max-w-4xl mx-auto mb-12 lg:hidden">
      <div class="flex flex-wrap gap-2 justify-center">
        {tocSections.map((s) => (
          <a href={`#${s.id}`} class="px-4 py-2 text-sm font-medium rounded-xl bg-white dark:bg-navy-800/60 border border-gray-200 dark:border-navy-700 text-slate-700 dark:text-slate-300 hover:border-primary-300 dark:hover:border-primary-700 hover:text-primary-700 dark:hover:text-primary-300 transition-all">{s.label}</a>
        ))}
      </div>
    </nav>

    <div class="lg:grid lg:grid-cols-[1fr_14rem] lg:gap-8 lg:max-w-6xl lg:mx-auto">
      <div class="space-y-16">

    <!-- Najważniejsze informacje -->
    <section id="najwazniejsze" class="scroll-mt-20">
      <div class="p-8 lg:p-10 rounded-3xl bg-primary-50 dark:bg-navy-800/60 border-2 border-primary-100 dark:border-primary-700/40 shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_16px_rgba(6,166,255,0.08)]">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white" >Najważniejsze informacje</h2>
        <dl class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4">
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">Nazwa</dt>
            <dd class="mt-1 text-slate-900 dark:text-white font-medium">Zespół Szkół Energetycznych i Usługowych (ZSEiU) w Łaziskach Górnych</dd>
          </div>
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">Adres</dt>
            <dd class="mt-1 text-slate-900 dark:text-white font-medium">ul. Chopina 11b, 43-170 Łaziska Górne</dd>
          </div>
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">Telefon</dt>
            <dd class="mt-1 text-slate-900 dark:text-white font-medium">32 224 24 15</dd>
          </div>
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">E-mail</dt>
            <dd class="mt-1"><a href="mailto:sekretariat@zseiulaziska.pl" class="text-primary-600 dark:text-primary-400 hover:underline font-medium">sekretariat@zseiulaziska.pl</a></dd>
          </div>
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">Dyrektor</dt>
            <dd class="mt-1 text-slate-900 dark:text-white font-medium">mgr Anna Jadasz</dd>
          </div>
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">Wicedyrektor</dt>
            <dd class="mt-1 text-slate-900 dark:text-white font-medium">mgr Dorota Brudny</dd>
          </div>
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">Kierownik szkolenia praktycznego</dt>
            <dd class="mt-1 text-slate-900 dark:text-white font-medium">mgr inż. Piotr Dębowski</dd>
          </div>
          <div class="flex flex-col">
            <dt class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">Statystyki (2025/2026)</dt>
            <dd class="mt-1 text-slate-900 dark:text-white font-medium">~520 uczniów, ~57 nauczycieli, 22 oddziały</dd>
          </div>
        </dl>
      </div>
    </section>

    

    <!-- Struktura organizacyjna -->
    <section id="struktura" class="scroll-mt-20">
      <h2 class="text-2xl font-bold text-center text-slate-900 dark:text-white mb-8" >Struktura organizacyjna</h2>
      <InfoStructure />
    </section>

    <!-- Kierunki kształcenia -->
    <section id="kierunki" class="scroll-mt-20">
      <div class="p-8 lg:p-10 rounded-3xl bg-gradient-to-br from-primary-50 to-primary-100 dark:from-navy-800 dark:to-navy-800/60 border-2 border-primary-200 dark:border-primary-700/40 shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_16px_rgba(6,166,255,0.08)]">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white text-center" >Kierunki kształcenia</h2>
        <p class="mt-2 text-center text-slate-600 dark:text-slate-400">Oferta edukacyjna:</p>
        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <h3 class="font-semibold text-slate-900 dark:text-white flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-primary-500"></span>
              Technikum Nr 1
            </h3>
            <ul class="mt-3 space-y-2">
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Technik elektryk
              </li>
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Technik informatyk
              </li>
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Technik logistyk (w tym klasa policyjna / mundurowa)
              </li>
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Technik urządzeń i systemów energetyki odnawialnej (OZE)
              </li>
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Technik organizacji turystyki
              </li>
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Technik stylista
              </li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 dark:text-white flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-primary-500"></span>
              Branżowa Szkoła I stopnia
            </h3>
            <ul class="mt-3 space-y-2">
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Mechanik-monter maszyn i urządzeń
              </li>
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Operator maszyn i urządzeń do przetwórstwa tworzyw sztucznych
              </li>

              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                klasa wielozawodowa
              </li>
            </ul>
            <h3 class="mt-6 font-semibold text-slate-900 dark:text-white flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-primary-500"></span>
              Branżowa Szkoła II stopnia
            </h3>
            <ul class="mt-3 space-y-2">
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Technik mechanik
              </li>
            </ul>
            <h3 class="mt-6 font-semibold text-slate-900 dark:text-white flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-primary-500"></span>
              Liceum Ogólnokształcące dla Dorosłych
            </h3>
            <ul class="mt-3 space-y-2">
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Profil ogólny &mdash; nauka bezpłatna, zaoczna
              </li>
            </ul>
          </div>
        </div>
        <div class="mt-8 text-center">
          <a href="/kierunki" class="inline-flex items-center gap-2 px-6 py-3 bg-primary-600 text-white rounded-xl font-semibold hover:bg-primary-700 transition-all duration-300 shadow-md hover:shadow-lg focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-primary-500 focus-visible:ring-offset-2">
            Szczegółowe kierunki
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Klasy mundurowe -->
    <section id="klasy-mundurowe" class="scroll-mt-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div class="p-8 rounded-3xl bg-white dark:bg-navy-800/90 border-2 border-slate-100 dark:border-navy-600 shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_12px_rgba(0,0,0,0.06)]">
          <h2 class="text-2xl font-bold text-slate-900 dark:text-white" >Klasy mundurowe</h2>
          <p class="mt-4 text-slate-600 dark:text-slate-300 leading-relaxed">
            ZSEiU prowadzi klasy mundurowe (m.in. klasa policyjna) &mdash; <strong class="text-slate-900 dark:text-white font-semibold">jedyna taka oferta w powiecie</strong>. Program łączy kształcenie zawodowe (technik logistyk) z dodatkowymi zajęciami taktycznymi, poligonami, strzelectwem i przygotowaniem do służb mundurowych.
          </p>
          <p class="mt-3 text-slate-600 dark:text-slate-300 leading-relaxed">
            Klasy funkcjonują pod patronatem Policji, co otwiera dodatkowe możliwości rozwoju zawodowego. Absolwenci otrzymują dodatkowe punkty przy rekrutacji do służby w Policji.
          </p>
          <a href="/klasy-mundurowe" class="mt-6 inline-flex items-center gap-2 text-primary-600 dark:text-primary-400 font-semibold hover:underline">
            Więcej o klasach mundurowych
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        <div class="p-8 rounded-3xl bg-white dark:bg-navy-800/90 border-2 border-slate-100 dark:border-navy-600 shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_12px_rgba(0,0,0,0.06)]">
          <h2 class="text-2xl font-bold text-slate-900 dark:text-white" >Współpraca z partnerami</h2>
          <p class="mt-4 text-slate-600 dark:text-slate-300 leading-relaxed">
            Szkoła współpracuje z wiodącymi firmami branżowymi:
          </p>
          <ul class="mt-4 space-y-3">
            <li class="flex items-start gap-3">
              <span class="mt-1 w-2 h-2 rounded-full bg-primary-500 flex-shrink-0"></span>
              <div>
                <strong class="text-slate-900 dark:text-white">TAURON SERWIS / TAURON WYTWARZANIE</strong>
                <p class="text-sm text-slate-600 dark:text-slate-400">Klasy patronackie i stypendia dla kierunku technik energetyk; doposażenie laboratoriów.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-2 h-2 rounded-full bg-primary-500 flex-shrink-0"></span>
              <div>
                <strong class="text-slate-900 dark:text-white">bekuplast S.A.</strong>
                <p class="text-sm text-slate-600 dark:text-slate-400">Współpraca w zakresie kierunku magazynier-logistyk, praktyki w warunkach rzeczywistych.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-2 h-2 rounded-full bg-primary-500 flex-shrink-0"></span>
              <div>
                <strong class="text-slate-900 dark:text-white">Polska Grupa Górnicza</strong>
                <p class="text-sm text-slate-600 dark:text-slate-400">Gwarancja zatrudnienia i stypendia dla uczniów kierunków górniczych.</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Infrastruktura i pracownie -->
    <section id="infrastruktura" class="scroll-mt-20">
      <h2 class="text-2xl font-bold text-center text-slate-900 dark:text-white mb-8" >Infrastruktura i pracownie</h2>
      <InfoInfrastructure />
    </section>

    <!-- Projekty i mobilności -->
    <section id="projekty" class="scroll-mt-20">
      <div class="p-8 lg:p-10 rounded-3xl bg-white dark:bg-navy-800/90 border-2 border-slate-100 dark:border-navy-600 shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_12px_rgba(0,0,0,0.06)]">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white text-center" >Projekty i mobilności międzynarodowe</h2>

        <div class="mt-8 grid grid-cols-1 lg:grid-cols-2 gap-8">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-primary-100 dark:bg-primary-800/40 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z" stroke="currentColor" stroke-width="2"/></svg>
              </div>
              <h3 class="font-semibold text-slate-900 dark:text-white">Erasmus+</h3>
            </div>
            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
              Akcja KA121 &mdash; akredytacja i dofinansowanie mobilności uczniów i nauczycieli (2024&ndash;2027).
            </p>
            <ul class="mt-3 space-y-2 text-sm text-slate-600 dark:text-slate-400">
              <li class="flex items-start gap-2">
                <span class="mt-1 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Grecja &bdquo;Pod stokami Olimpu&rdquo; &mdash; praktyki w Nei Pori
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Włochy &bdquo;U podnóża Etny&rdquo; &mdash; praktyki na Sycylii / w Katanii
              </li>
            </ul>
            <a href="/erasmus" class="mt-4 inline-flex items-center gap-1 text-sm text-primary-600 dark:text-primary-400 font-medium hover:underline">
              Więcej o Erasmus+
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>

          <div>
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-primary-100 dark:bg-primary-800/40 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <h3 class="font-semibold text-slate-900 dark:text-white">Projekty EFS i regionalne</h3>
            </div>
            <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
              <li class="flex items-start gap-2">
                <span class="mt-1 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                &bdquo;Efektywne Funkcjonalne Szkoły&rdquo;
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                &bdquo;Profesjonalny Mikołowski&rdquo; i &bdquo;Zawodowy Mikołowski&rdquo;
              </li>
              <li class="flex items-start gap-2">
                <span class="mt-1 w-1.5 h-1.5 rounded-full bg-primary-400 flex-shrink-0"></span>
                Narodowy Program Rozwoju Czytelnictwa (dofinansowanie biblioteki)
              </li>
            </ul>
            <a href="/projekty" class="mt-4 inline-flex items-center gap-1 text-sm text-primary-600 dark:text-primary-400 font-medium hover:underline">
              Więcej o projektach
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>

        <!-- Praktyki i kursy -->
        <div class="mt-8 pt-8 border-t border-gray-200 dark:border-navy-700">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <h3 class="font-semibold text-slate-900 dark:text-white">Praktyki zawodowe i staże</h3>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
                Szkoła organizuje praktyki zawodowe i staże lokalne oraz zagraniczne. Dokumenty (porozumienia, dzienniczki, programy) dostępne do pobrania.
              </p>
            </div>
            <div>
              <h3 class="font-semibold text-slate-900 dark:text-white">Kursy i uprawnienia</h3>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
                Uczniowie mogą zdobyć dodatkowe kwalifikacje: kurs operatora wózka jezdniowego, kurs spawania, prawo jazdy kat. B, certyfikaty SEP (dla energetyków).
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Dokumenty i polityki -->
    <section id="dokumenty" class="scroll-mt-20">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="p-6 rounded-xl bg-white dark:bg-navy-800/60 border border-gray-200 dark:border-navy-700 shadow-sm">
          <h2 class="text-lg font-bold text-slate-900 dark:text-white" >Dokumenty i polityki</h2>
          <ul class="mt-4 space-y-2 text-sm">
            <li><a href="/dokumenty-szkolne" class="text-primary-600 dark:text-primary-400 hover:underline">Statuty szkół (Technikum, BS1S, LO dla Dorosłych)</a></li>
            <li><a href="/rodo" class="text-primary-600 dark:text-primary-400 hover:underline">Polityka RODO i ochrona danych osobowych</a></li>
            <li><a href="/dostepnosc" class="text-primary-600 dark:text-primary-400 hover:underline">Deklaracja dostępności</a></li>
            <li><a href="/dokumenty" class="text-primary-600 dark:text-primary-400 hover:underline">Standardy ochrony małoletnich</a></li>
          </ul>
        </div>
        <div class="p-6 rounded-xl bg-white dark:bg-navy-800/60 border border-gray-200 dark:border-navy-700 shadow-sm">
          <h2 class="text-lg font-bold text-slate-900 dark:text-white" >Rekrutacja</h2>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
            Regulaminy rekrutacji dla Technikum, Branżowej Szkoły I i II stopnia oraz LO dla Dorosłych dostępne są w formacie PDF.
          </p>
          <a href="/rekrutacja" class="mt-3 inline-flex items-center gap-1 text-sm text-primary-600 dark:text-primary-400 font-medium hover:underline">
            Zasady rekrutacji
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Kontakt -->
    <section id="kontakt" class="scroll-mt-20">
      <div class="p-8 lg:p-10 rounded-3xl bg-gradient-to-br from-primary-50 to-primary-100 dark:from-navy-800 dark:to-navy-800/60 border-2 border-primary-200 dark:border-primary-700/40 text-center shadow-[inset_-2px_-2px_8px_rgba(0,0,0,0.02),4px_4px_16px_rgba(6,166,255,0.08)]">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white" >Kontakt i sekretariat</h2>
        <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div>
            <p class="text-sm font-semibold text-primary-700 dark:text-primary-300 uppercase tracking-wider">Adres</p>
