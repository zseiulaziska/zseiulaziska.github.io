---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="space-y-20">
    <!-- Hero -->
    <section class="text-center space-y-2 py-2">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-gray-900 dark:text-white">
        Kontakt
      </h1>
      <p class="text-lg text-gray-600 dark:text-slate-400 max-w-2xl mx-auto">
        Zespół Szkół Energetycznych i&nbsp;Usługowych w&nbsp;Łaziskach Górnych
      </p>
    </section>

    <!-- Dane podstawowe -->
    <section class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <div class="rounded-xl border border-gray-200 dark:border-navy-700 bg-white dark:bg-navy-800 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100 dark:bg-primary-700/30 text-primary-500 dark:text-primary-300">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Adres szkoły</h2>
        </div>
        <address class="not-italic text-gray-600 dark:text-slate-400 space-y-1">
          <p>ul. Chopina 11b</p>
          <p>43-170 Łaziska Górne</p>
        </address>
      </div>

      <div class="rounded-xl border border-gray-200 dark:border-navy-700 bg-white dark:bg-navy-800 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100 dark:bg-primary-700/30 text-primary-500 dark:text-primary-300">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Telefon</h2>
        </div>
        <p class="text-gray-600 dark:text-slate-400">
          <a href="tel:322242415" class="text-primary-500 dark:text-primary-300 hover:underline font-medium">32 224 24 15</a>
        </p>
      </div>

      <div class="rounded-xl border border-gray-200 dark:border-navy-700 bg-white dark:bg-navy-800 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100 dark:bg-primary-700/30 text-primary-500 dark:text-primary-300">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">E-mail</h2>
        </div>
        <p class="text-gray-600 dark:text-slate-400">
          <a href="mailto:sekretariat@zseiulaziska.pl" class="text-primary-500 dark:text-primary-300 hover:underline font-medium break-all">sekretariat@zseiulaziska.pl</a>
        </p>
      </div>
    </section>

    <!-- Sekretariat -->
    <section class="rounded-xl border border-gray-200 dark:border-navy-700 bg-white dark:bg-navy-800 p-6 shadow-sm">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-100 dark:bg-primary-700/30 text-primary-500 dark:text-primary-300">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
            <path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Sekretariat</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <p class="text-sm text-gray-500 dark:text-slate-500 mb-1">Godziny pracy</p>
          <p class="text-gray-900 dark:text-white font-medium">poniedziałek – piątek<br>7:30 – 15:00</p>
        </div>
        <div>
          <p class="text-sm text-gray-500 dark:text-slate-500 mb-1">Dane kontaktowe</p>
          <ul class="space-y-1 text-gray-900 dark:text-white">
            <li>Tel.: <a href="tel:322242415" class="text-primary-500 dark:text-primary-300 hover:underline">32 224 24 15</a></li>
            <li>E-mail: <a href="mailto:sekretariat@zseiulaziska.pl" class="text-primary-500 dark:text-primary-300 hover:underline">sekretariat@zseiulaziska.pl</a></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Dyrekcja -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Dyrekcja i kierownictwo</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-gray-200 dark:border-navy-700 bg-white dark:bg-navy-800 p-6 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary-500 dark:text-primary-300 mb-1">Dyrektor</p>
          <p class="text-lg font-semibold text-gray-900 dark:text-white">mgr Anna Jadasz</p>
          <p class="text-sm text-gray-500 dark:text-slate-400 mt-1">
            <a href="mailto:anna.jadasz@zseiulaziska.pl" class="text-primary-500 dark:text-primary-300 hover:underline">anna.jadasz@zseiulaziska.pl</a>
          </p>
        </div>
        <div class="rounded-xl border border-gray-200 dark:border-navy-700 bg-white dark:bg-navy-800 p-6 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary-500 dark:text-primary-300 mb-1">Wicedyrektor</p>
          <p class="text-lg font-semibold text-gray-900 dark:text-white">mgr Dorota Brudny</p>
          <p class="text-sm text-gray-500 dark:text-slate-400 mt-1">
            <a href="mailto:dorota.brudny@zseiulaziska.pl" class="text-primary-500 dark:text-primary-300 hover:underline">dorota.brudny@zseiulaziska.pl</a>
          </p>
        </div>
        <div class="rounded-xl border border-gray-200 dark:border-navy-700 bg-white dark:bg-navy-800 p-6 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary-500 dark:text-primary-300 mb-1">Kierownik szkolenia praktycznego</p>
          <p class="text-lg font-semibold text-gray-900 dark:text-white">mgr inż. Piotr Dębowski</p>
          <p class="text-sm text-gray-500 dark:text-slate-400 mt-1">
            <a href="mailto:piotr.debowski@zseiulaziska.pl" class="text-primary-500 dark:text-primary-300 hover:underline">piotr.debowski@zseiulaziska.pl</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Social media -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Media społecznościowe</h2>
      <div class="flex flex-wrap gap-4">
        <a href="https://www.facebook.com/zseiu" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-3 rounded-xl border border-gray-200 dark:border-navy-700 bg-white dark:bg-navy-800 px-6 py-4 shadow-sm hover:shadow-md hover:border-primary-200 dark:hover:border-primary-700 transition-all">
          <svg class="h-6 w-6 text-[#1877F2]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          <span class="font-medium text-gray-900 dark:text-white">Facebook</span>
        </a>
        <a href="https://www.instagram.com/zseiu_laziska/" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-3 rounded-xl border border-gray-200 dark:border-navy-700 bg-white dark:bg-navy-800 px-6 py-4 shadow-sm hover:shadow-md hover:border-primary-200 dark:hover:border-primary-700 transition-all">
          <svg class="h-6 w-6 text-[#E4405F]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
          <span class="font-medium text-gray-900 dark:text-white">Instagram</span>
        </a>
      </div>
    </section>

    <!-- BIP -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Biuletyn Informacji Publicznej</h2>
      <a href="https://zseiu.ssdip.bip.gov.pl/" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-3 rounded-xl border border-gray-200 dark:border-navy-700 bg-white dark:bg-navy-800 px-6 py-4 shadow-sm hover:shadow-md hover:border-primary-200 dark:hover:border-primary-700 transition-all">
        <img src="/images/bip_simple.svg" alt="BIP" class="h-6 w-auto" />
        <span class="font-medium text-gray-900 dark:text-white">BIP ZSEiU</span>
      </a>
    </section>

    <!-- Dodatkowe informacje -->
    <section class="rounded-xl border border-gray-200 dark:border-navy-700 bg-white dark:bg-navy-800 p-6 shadow-sm">
      <h2 class="flex items-center gap-3 text-lg font-semibold text-gray-900 dark:text-white mb-4">
        <svg class="h-5 w-5 text-primary-500 dark:text-primary-300" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
          <path d="M12 16v-4M12 8h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Dodatkowe informacje
      </h2>
      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-slate-400 mb-2">Dojazd i parking</h3>
          <p class="text-gray-600 dark:text-slate-400">Przy szkole znajduje się duży parking. Wejście główne od ul. Chopina. Dojazd komunikacją miejską.</p>
        </div>
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-slate-400 mb-2">Dostępność</h3>
          <p class="text-gray-600 dark:text-slate-400">
            Osoba do kontaktu w sprawach dostępności: <a href="mailto:anna.jadasz@zseiulaziska.pl" class="text-primary-500 dark:text-primary-300 hover:underline">Anna Jadasz</a>
          </p>
        </div>
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-slate-400 mb-2">RODO</h3>
          <p class="text-gray-600 dark:text-slate-400">
            Administratorem danych osobowych jest ZSEiU. W sprawach ochrony danych kontaktuj się z sekretariatem szkoły.
          </p>
        </div>
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-slate-400 mb-2">Dokumenty</h3>
          <p class="text-gray-600 dark:text-slate-400">
            Statuty, regulaminy i polityki dostępne są w zakładce <a href="/dokumenty" class="text-primary-500 dark:text-primary-300 hover:underline">Dokumenty i polityki</a>.
          </p>
        </div>
      </div>
    </section>

    <!-- Mapa -->
    <section class="rounded-xl border border-gray-200 dark:border-navy-700 overflow-hidden shadow-sm">
      <h2 class="sr-only">Mapa dojazdu</h2>
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2550.122!2d18.838778!3d50.152851!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x471141ab9c79b9b3%3A0x8e0b0c43d5b1f8a7!2sZesp%C3%B3%C5%82%20Szk%C3%B3%C5%82%20Energetycznych%20i%20Us%C5%82ugowych!5e0!3m2!1spl!2spl!4v1"
        width="100%" height="350" style="border:0; display: block;" allowfullscreen loading="lazy"
        title="Mapa lokalizacji szkoły">
      </iframe>
    </section>
  </div>
</Layout>
