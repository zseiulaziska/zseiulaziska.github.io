---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Plan lekcji – ZSEiU Łaziska Górne" description="Plan lekcji ZSEiU Łaziska Górne - aktualny rozkład zajęć dla wszystkich klas technikum i szkoły branżowej.">

  <article class="w-full max-w-6xl mx-auto min-w-0 px-4 sm:px-6">

    <div class="mt-12 mb-6 border-l-4 border-primary-500 pl-3 sm:pl-4">
      <h2 class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white leading-snug wrap-break-word">Plan lekcji</h2>
    </div>

    <p class="text-base sm:text-lg leading-relaxed text-slate-700 dark:text-slate-300 mb-6 wrap-break-word">
      Aktualny plan zajęć dla wszystkich klas. Plan wyświetlany jest w widoku pełnoekranowym z możliwością wyboru klasy i dnia.
    </p>

    <div class="rounded-2xl overflow-hidden border border-slate-200 dark:border-navy-700 bg-white dark:bg-navy-800/70 shadow-xs mb-16">
      <iframe
        src="https://zseiulaziska.github.io/plan-lekcji-vulcan/"
        class="w-full border-0"
        style="height: calc(100vh - 240px); min-height: 600px;"
        title="Plan lekcji ZSEiU"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>

  </article>

</Layout>